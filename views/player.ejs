<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jukebar - Player</title>
    <link rel="icon" href="/img/favicon.png">
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>

</head>

<body class="player-page">
    <div id="notification" class="notification">
        <span class="close-btn" id="close-notification">&times;</span>
        <p id="notification-text"></p>
    </div>
    <%- include('partials/header', { page: 'player' }) %>
        <div class="main-content player-main-content">
            <div class="player-topbar">
                <p class="user-greeting">Logged in as: <strong>
                        <%= user %>
                    </strong> <span class="user-count">(<span id="onlineUserCount">1</span> online)</span></p>
            </div>

            <div class="player-shell">
                <aside class="player-sidebar" aria-label="Playlists">
                    <div class="player-sidebar-header">
                        <div class="player-sidebar-tabs">
                            <button class="sidebar-tab active" id="tab-playlists"
                                onclick="switchSidebarTab('playlists')">Teacher Playlists</button>
                            <button class="sidebar-tab" id="tab-my-playlists"
                                onclick="switchSidebarTab('my-playlists')">Class Playlists</button>
                        </div>
                    </div>
                    <div id="tab-playlists-panel">
                        <div id="studentPlaylistsList" class="player-sidebar-list">
                            <p style="text-align:center;color:#b3b3b3;">Loading...</p>
                        </div>
                    </div>
                    <div id="tab-my-playlists-panel" style="display:none;">
                        <div class="player-sidebar-list-actions">
                            <button class="primary small-btn" id="createPlaylistBtn"
                                onclick="openCreatePlaylistModal()">+ New Playlist</button>
                        </div>
                        <div id="myPlaylistsList" class="player-sidebar-list">
                            <p style="text-align:center;color:#b3b3b3;">Loading...</p>
                        </div>
                    </div>
                </aside>

                <main class="player-main" aria-label="Search">
                    <div id="spotifyPlayer" class="player-search-panel">
                        <form id="searchForm">
                            <div class="search-container">
                                <input type="text" id="searchInput" placeholder="Search for a song, artist, or album"
                                    required>
                                <button type="submit" id="searchButton">
                                    <img src="/img/search.png" alt="Search" class="search-icon">
                                </button>
                            </div>
                        </form>
                        <% if (ownerIDs.includes(userID)) { %>
                            <div class="owner-anon-container">
                                <label class="owner-anon-label">
                                    <input type="checkbox" id="owner-anon-mode">
                                    Add songs anonymously
                                </label>
                            </div>
                            <% } %>
                                <div id="searchFilterTabs" class="search-filter-tabs" style="display:none;">
                                    <button class="search-filter-tab active" data-filter="all">All</button>
                                    <button class="search-filter-tab" data-filter="songs">Songs</button>
                                    <button class="search-filter-tab" data-filter="artists">Artists</button>
                                    <button class="search-filter-tab" data-filter="albums">Albums</button>
                                </div>
                                <div id="searchResults"></div>
                    </div>
                </main>

                <aside class="player-right-rail" aria-label="Now playing details">
                    <div class="player-rail-title">Queue</div>
                    <div id="queue" class="player-rail-queue"></div>
                </aside>
            </div>
        </div>

        <footer class="player-bottom-bar" aria-label="Now playing">
            <div id="songStats" class="player-nowplaying">
                <div class="player-nowplaying-left">
                    <div id="currentlyPlaying"></div>
                </div>
                <div class="player-nowplaying-center">
                    <div class="player-controls" aria-label="Playback controls">
                        <button id="now-ban-button" class="player-control-btn player-control-btn--action" type="button"
                            aria-label="Vote Ban" title="Vote Ban" disabled>
                            <img src="/img/ban.png" alt="Ban" class="player-control-icon">
                        </button>
                        <button id="skip-button" class="player-control-btn player-control-btn--primary" type="button"
                            aria-label="Skip" disabled>
                            <div id="skip-button-showie-shield">
                                1
                            </div>
                            <img src="/img/skip.png" alt="Skip" class="player-control-icon player-control-icon--skip">
                        </button>
                        <button id="now-shield-button" class="player-control-btn player-control-btn--action"
                            type="button" aria-label="Skip Shield" title="Skip Shield" disabled>
                            <img src="/img/skipShield.png" alt="Skip Shield" class="player-control-icon">
                        </button>
                    </div>
                </div>
                <div class="player-nowplaying-right">
                </div>
            </div>
        </footer>
        <div id="paymentModal" class="payment-modal">
            <div class="payment-content">
                <button id="hide-payment">&times;</button>

                <%- include('partials/pay') %>
            </div>
        </div>

        <div id="playlistPaymentModal" class="payment-modal" style="display:none;">
            <div class="payment-content playlist-pay-content">
                <h3 class="ban-reason-title">Play Playlist</h3>
                <div class="playlist-pay-summary">
                    <div id="playlistPayTitle" class="playlist-pay-title">Playlist</div>
                    <div id="playlistPayMeta" class="playlist-pay-meta">0 queueable tracks</div>
                    <div id="playlistPayCost" class="playlist-pay-cost">0 Digipogs</div>
                </div>
                <p style="color:#ffaa00; font-size:0.85em; text-align:center; margin:8px 0;">Note: Playing a playlist
                    will clear the current queue.</p>
                <input id="playlist-pay-pin" type="password" pattern="\d*" inputmode="numeric" maxlength="6"
                    placeholder="Enter PIN" oninput="this.value = this.value.replace(/[^0-9]/g,'');" />
                <label class="medium label-inline playlist-pay-save" for="playlistSavePIN">
                    Save PIN for next purchase
                    <input id="playlistSavePIN" type="checkbox" />
                </label>
                <div class="ban-reason-actions" style="display:flex; gap:8px; justify-content:flex-start;">
                    <button id="playlist-pay-confirm" class="unban-button" type="button">Pay & Queue</button>
                    <button id="playlist-pay-cancel" class="ban-button" type="button">Cancel</button>
                </div>
            </div>
        </div>

        <div id="ownerShieldModal" class="owner-shield-modal">
            <div class="owner-shield-content">
                <button id="owner-shield-close" class="owner-shield-close">&times;</button>
                <h3 class="owner-shield-title"><img src="/img/skipShield.png" alt="Shield" class="notify-shield-icon">
                    Add Skip Shields</h3>
                <div class="shield-quantity-section" style="display:block;">
                    <label class="shield-quantity-label">How many shields?</label>
                    <input type="number" id="owner-shield-quantity-input" class="shield-quantity-input" min="1"
                        max="1000" placeholder="1"
                        onkeydown="if(['+','-','.','e','E'].includes(event.key)) event.preventDefault();" oninput="
                            this.value = this.value.replace(/[^0-9]/g, '');
                            let v = parseInt(this.value) || 1;
                            if (v > 1000) {
                                Notify('You\'ve reached the maximum of 1000 shields', 'error');
                                v = 1000;
                                this.value = v;
                            }
                            if (v < 1) this.value = 1;
                            pendingShieldQuantity = v;
                        ">
                </div>
                <button id="owner-shield-confirm" class="owner-shield-confirm-btn">Add Shields</button>
            </div>
        </div>

        <!-- Create Custom Playlist Modal -->
        <div id="createPlaylistModal" class="payment-modal" style="display:none;">
            <div class="payment-content playlist-modal-content">
                <button class="close-modal-btn" onclick="closeCreatePlaylistModal()">
                    <img src="img/close.svg" alt="Close" style="width:16px;height:16px;filter:invert(1)">
                </button>
                <h3 class="ban-reason-title">Create Custom Playlist</h3>
                <div class="playlist-modal-body">
                    <p class="playlist-modal-help">Name your playlist and add up to 5 songs for free. Additional songs
                        cost <%= addPlaylistSongAmount %> digipogs each.</p>
                    <div class="row playlist-modal-field">
                        <label class="small">Playlist Name</label>
                        <input type="text" id="newPlaylistName" maxlength="100" placeholder="My Awesome Playlist" />
                    </div>
                    <div class="playlist-modal-body-but-better">
                        <div class="playlist-modal-field create-playlist-songs">
                            <label class="small">Initial Songs (up to 5)</label>
                            <form id="createPlaylistSearchForm" class="playlist-modal-search-form">
                                <div class="search-container">
                                    <input type="text" id="createPlaylistSearchInput" placeholder="Search for a song" />
                                    <button type="submit" class="primary playlist-modal-search-btn">Search</button>
                                </div>
                            </form>
                            <div id="createPlaylistSearchResults" class="playlist-search-results"></div>
                        </div>
                        <div id="createPlaylistSelectedSongs" class="playlist-selected-songs"></div>
                    </div>
                </div>
                <div class="playlist-modal-footer ban-reason-actions">
                    <button class="unban-button" onclick="submitCreatePlaylist()">Create</button>
                    <button class="ban-button" onclick="closeCreatePlaylistModal()">Cancel</button>
                </div>
            </div>
        </div>

        <!-- Custom Playlist Modal -->
        <div id="customPlaylistTracksModal" class="payment-modal" style="display:none;">
            <div class="payment-content playlist-modal-content">
                <button class="close-modal-btn" onclick="closeCustomPlaylistTracksModal()">
                    <img src="img/close.svg" alt="Close" style="width:16px;height:16px;filter:invert(1)">
                </button>
                <h3 class="ban-reason-title" id="customPlaylistTracksTitle">Custom Playlist</h3>
                <div id="customPlaylistTracksList" class="playlist-tracks-list">
                    <p style="color:#b3b3b3;text-align:center;padding:12px;">Loading tracks...</p>
                </div>
                <div class="playlist-modal-actions">
                    <button class="primary small-btn" onclick="playCurrentCustomPlaylist()">▶ Play Playlist</button>
                    <button id="customPlaylistAddSongBtn" class="primary small-btn"
                        onclick="openAddSongToCustomPlaylist()">+ Add Song</button>
                </div>
            </div>
        </div>

        <!-- Add Song to Custom Playlist Modal -->
        <div id="addSongToPlaylistModal" class="payment-modal" style="display:none;">
            <div class="payment-content playlist-modal-content">
                <button class="close-modal-btn" onclick="closeAddSongToPlaylistModal()">
                    <img src="img/close.svg" alt="Close" style="width:16px;height:16px;filter:invert(1)">
                </button>
                <h3 class="ban-reason-title" id="addSongToPlaylistTitle">Custom Playlist</h3>
                <form id="addSongSearchForm" class="playlist-modal-search-form playlist-modal-search-form--compact">
                    <div class="search-container">
                        <input type="text" id="addSongSearchInput" placeholder="Search for a song" />
                        <button type="submit" class="primary playlist-modal-search-btn">Search</button>
                    </div>
                </form>
                <div id="addSongSearchResults" class="playlist-search-results"></div>
            </div>
        </div>

        <div id="customPlaylistContextMenu" class="playlist-context-menu" style="display:none;" role="menu"
            aria-label="Custom playlist actions">
            <button id="customPlaylistMenuPlay" type="button" role="menuitem">Play Playlist</button>
            <button id="customPlaylistMenuAdd" type="button" role="menuitem">Add More Songs</button>
        </div>

        <!-- Artist Modal -->
        <div id="artistModal" class="payment-modal" style="display:none;">
            <div class="payment-content playlist-modal-content artist-modal-content">
                <button class="close-modal-btn" id="artistModalClose">
                    <img src="img/close.svg" alt="Close" style="width:16px;height:16px;filter:invert(1)">
                </button>
                <div id="artistModalHeader" class="artist-modal-header"></div>
                <div id="artistOverviewView">
                    <div id="artistTopTracksSection">
                        <h4 class="artist-modal-section-title">Popular Tracks</h4>
                        <div id="artistTopTracksList" class="artist-tracks-list"></div>
                    </div>
                    <div id="artistAlbumsSection">
                        <h4 class="artist-modal-section-title">Albums & Singles</h4>
                        <div id="artistAlbumGrid" class="artist-album-grid"></div>
                    </div>
                </div>
                <div id="albumDetailView" style="display:none;">
                    <div id="albumDetailHeader" class="album-detail-header"></div>
                    <div class="album-detail-tracks-wrap">
                        <div id="albumDetailTracksList" class="artist-tracks-list"></div>
                    </div>
                </div>
            </div>
        </div>


        <button id="changelog-button" class="changelog-button" title="View Changelog">
            <img src="/img/changelog.png" alt="Changelog">
        </button>

        <div id="changelogModal" class="changelog-modal">
            <div class="changelog-content">
                <button id="close-changelog" class="close-changelog">&times;</button>
                <%- include('partials/changelog') %>
            </div>
        </div>

        <div id="banVoteModal" class="ban-vote-modal minimized" style="display: none;">
            <div class="ban-vote-header">
                <span id="banVoteStatus">Ban vote in progress...</span>
                <button id="banVoteMinimize" class="ban-vote-minimize-btn" title="Minimize/Maximize">−</button>
            </div>
            <div class="ban-vote-content">
                <h3 id="banVoteTitle"></h3>
                <div class="ban-vote-details">
                    <div class="vote-counts">
                        <span>Yes: <strong id="banVoteYes">0</strong></span>
                        <span>No: <strong id="banVoteNo">0</strong></span>
                        <span>Online: <strong id="banVoteOnline">0</strong></span>
                    </div>
                    <div class="vote-buttons">
                        <button onclick="castVote('yes')" class="vote-yes-btn">Vote Yes</button>
                        <button onclick="castVote('no')" class="vote-no-btn">Vote No</button>
                    </div>
                    <div id="vote-timer" class="vote-timer">45s remaining</div>
                </div>
            </div>
        </div>

        <script>
            // Notification functions - MUST be defined FIRST before any includes
            let notificationTimeout;

            function Notify(message, type = 'info', iconSrc = null) {
                let notification = document.getElementById("notification");
                let notificationText = document.getElementById("notification-text");

                notificationText.textContent = '';
                if (iconSrc) {
                    const icon = document.createElement('img');
                    icon.src = iconSrc;
                    icon.alt = '';
                    icon.className = 'notify-shield-icon';
                    notificationText.appendChild(icon);
                    notificationText.appendChild(document.createTextNode(' ' + message));
                } else {
                    notificationText.textContent = message;
                }

                // Remove any existing type classes
                notification.classList.remove('notification-success', 'notification-error', 'notification-info');

                // Add the appropriate type class
                if (type === 'error') {
                    notification.classList.add('notification-error');
                } else {
                    // default to success for other types
                    notification.classList.add('notification-success');
                }

                notification.style.display = "block";
                setTimeout(() => notification.style.opacity = "1", 100);

                clearTimeout(notificationTimeout);
                notificationTimeout = setTimeout(closeNotification, 5000);
            }

            function closeNotification() {
                let notification = document.getElementById("notification");
                clearTimeout(notificationTimeout);

                notification.style.opacity = "0";
                setTimeout(() => notification.style.display = "none", 500);
            }

            const userPermission = <%= userPermission %>;

            // Global payment status flags - MUST be at top for songMenu.ejs to access
            let hasPaid = <%= JSON.stringify(hasPaid || false) %>;
            let pendingTrackUri = null;
            let pendingTrackAddedAt = null;
            let pendingTrackName = null;
            let pendingTrackArtist = null;
            let pendingBanReason = null;
            let pendingAction = null;
            let pendingShieldQuantity = 1;
            let pendingPlaylistId = null;
            let selectedPlaylistQuote = null;

            // Custom playlist state
            let pendingTrackMeta = {};
            let pendingCustomPlaylistId = null;
            let pendingCustomPlaylistName = null;
            let pendingCustomPlaylistTrackUri = null;
            let createPlaylistSelectedUris = [];
            let currentCustomPlaylistId = null;
            let currentCustomPlaylistName = null;
            let currentCustomPlaylistCanEdit = false;
            let customPlaylistContextTarget = null;
            let userIsBanned = false;

            // Global letiables that need to be accessed by multiple functions
            let currentlyPlayingUri = null;
            let currentProgress = 0; // Current progress in ms
            let currentDuration = 0; // Track duration in ms
            let isCurrentlyPlaying = false;
            let progressInterval = null;
            let currentID = <%= JSON.stringify(userID || null) %>; // User ID which is needed by ban votes
            const ownerIDs = <%= JSON.stringify(ownerIDs) %>; // Array of owner ids

            // Helper function to check if a user ID is an owner
            function isOwnerClient(uid) {
                return ownerIDs.includes(Number(uid));
            }

            // Create socket globally one time and expose it immediately
            const socket = io();
            window.banVoteSocket = socket;
        </script>

        <%- include('partials/songMenu') %>

            <script>
                let currentTrackActionState = null;

                (function () {
                    'use strict';

                    let useJukebar = true;

                    async function fetchAllowedPlaylistsForSidebar() {
                        const list = document.getElementById('studentPlaylistsList');
                        if (!list) return;

                        list.innerHTML = '<p style="text-align:center;color:#b3b3b3;">Loading...</p>';

                        try {
                            const res = await fetch('/api/playlists/allowed', { headers: { 'Accept': 'application/json' } });
                            const data = await res.json().catch(() => ({}));
                            if (!res.ok || !data.ok) throw new Error(data.error || 'Failed to load playlists');

                            const playlists = data.playlists || [];
                            if (!playlists.length) {
                                list.innerHTML = '<p style="text-align:center;color:#b3b3b3;">No playlists yet.</p>';
                                return;
                            }

                            list.innerHTML = '';
                            playlists.slice(0, 30).forEach((p) => {
                                const row = document.createElement('button');
                                row.type = 'button';
                                row.className = 'player-sidebar-item';
                                row.title = p.name || 'Playlist';

                                const img = document.createElement('img');
                                img.className = 'player-sidebar-cover';
                                img.src = p.image || '/img/placeholder.png';
                                img.alt = p.name || 'Playlist';

                                const meta = document.createElement('div');
                                meta.className = 'player-sidebar-meta';

                                const name = document.createElement('div');
                                name.className = 'player-sidebar-name';
                                name.textContent = p.name || 'Untitled Playlist';

                                const sub = document.createElement('div');
                                sub.className = 'player-sidebar-sub';
                                sub.textContent = p.owner ? `By ${p.owner}` : 'Playlist';

                                meta.appendChild(name);
                                meta.appendChild(sub);

                                row.appendChild(img);
                                row.appendChild(meta);

                                row.addEventListener('click', () => handlePlaylistClick(p));

                                list.appendChild(row);
                            });
                        } catch (err) {
                            console.error('Sidebar playlists load error:', err);
                            list.innerHTML = '<p style="text-align:center;color:#ff4444;">Failed to load playlists.</p>';
                        }
                    }

                    async function handlePlaylistClick(playlist) {
                        if (userIsBanned) {
                            Notify('You are banned from using Jukebar.', 'error');
                            return;
                        }

                        Notify('Loading playlist...', 'success');

                        // Owners skip payment — queue directly
                        if (isOwnerClient(currentID)) {
                            await queuePlaylist(playlist.id);
                            return;
                        }

                        // Get a cost quote first
                        try {
                            const quoteRes = await fetch('/api/playlists/quote', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ playlistId: playlist.id })
                            });
                            const quoteData = await quoteRes.json();
                            if (!quoteRes.ok || !quoteData.ok) {
                                Notify(quoteData.error || 'Cannot play this playlist', 'error');
                                return;
                            }

                            if (!quoteData.queueableCount || quoteData.cost <= 0) {
                                Notify('No queueable tracks in this playlist right now.', 'error');
                                return;
                            }

                            // Show the dedicated playlist payment modal
                            selectedPlaylistQuote = {
                                playlistId: playlist.id,
                                playlist: quoteData.playlist,
                                queueableCount: quoteData.queueableCount,
                                cost: quoteData.cost
                            };
                            document.getElementById('playlistPayTitle').textContent = quoteData.playlist?.name || 'Playlist';
                            document.getElementById('playlistPayMeta').textContent = `${quoteData.queueableCount} queueable tracks`;
                            document.getElementById('playlistPayCost').textContent = `${quoteData.cost} Digipogs`;
                            document.getElementById('playlistPaymentModal').style.display = 'block';
                            document.querySelector('.main-content').classList.add('blurred');
                        } catch (err) {
                            console.error('Playlist quote error:', err);
                            Notify('Something went wrong. Try again.', 'error');
                        }
                    }

                    async function queuePlaylist(playlistId) {
                        try {
                            const res = await fetch('/api/playlists/queue', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ playlistId })
                            });
                            const data = await res.json();
                            if (res.ok && data.ok) {
                                Notify(data.message || 'Playlist is now playing!', 'success');
                            } else {
                                Notify(data.error || 'Failed to play playlist', 'error');
                            }
                        } catch (err) {
                            console.error('Queue playlist error:', err);
                            Notify('Something went wrong. Try again.', 'error');
                        }
                    }


                    // Check if user is banned on page load
                    async function checkBanStatus() {
                        try {
                            const res = await fetch('/api/me/banned', { headers: { 'Accept': 'application/json' } });
                            if (res.ok) {
                                const data = await res.json();
                                if (data.banned) {
                                    userIsBanned = true;
                                    showBanBanner();
                                }
                            }
                        } catch (err) {
                            console.error('Error checking ban status:', err);
                        }
                    }

                    function showBanBanner() {
                        // Remove existing banner if any
                        const existing = document.getElementById('ban-banner');
                        if (existing) existing.remove();

                        const banner = document.createElement('div');
                        banner.id = 'ban-banner';
                        banner.style.cssText = 'position:fixed;bottom:0;left:0;right:0;z-index:10000;background:#ff4444;color:#fff;text-align:center;padding:12px 16px;font-weight:600;font-size:1rem;box-shadow:0 -2px 8px rgba(0,0,0,0.3);';
                        banner.textContent = 'You have been banned from Jukebar. LOL COULD NOT BE ME AHAHAHAHAHAH';
                        document.body.appendChild(banner);
                    }

                    checkBanStatus();
                    fetchAllowedPlaylistsForSidebar();

                    document.getElementById('now-ban-button')?.addEventListener('click', async () => {
                        const actionTrack = currentTrackActionState;
                        if (!actionTrack) {
                            Notify('No track is currently playing.', 'error');
                            return;
                        }
                        if (userIsBanned) {
                            Notify('You have been banned from Jukebar. Contact your teacher.', 'error');
                            return;
                        }

                        try {
                            const res = await fetch('/api/online-count');
                            const data = await res.json().catch(() => ({}));
                            const onlineCount = data.count || 0;
                            if (onlineCount < 5) {
                                Notify('At least 5 users must be online to start a ban vote', 'error');
                                return;
                            }
                        } catch (err) {
                            console.error('Failed to check online count:', err);
                            Notify('Failed to verify online users. Please try again.', 'error');
                            return;
                        }

                        const userIsOwner = isOwnerClient(currentID);
                        if (userIsOwner) {
                            startBanVote(actionTrack.uri, actionTrack.name, actionTrack.artist, 'student ban', actionTrack.image);
                        } else {
                            pendingAction = 'Ban Vote';
                            pendingTrackUri = actionTrack.uri;
                            pendingTrackName = actionTrack.name;
                            pendingTrackArtist = actionTrack.artist;
                            pendingBanReason = 'student ban';
                            pendingTrackMeta = { image: actionTrack.image || '' };
                            showPayment();
                        }
                    });

                    document.getElementById('now-shield-button')?.addEventListener('click', async () => {
                        const actionTrack = currentTrackActionState;
                        if (!actionTrack?.uri) {
                            Notify('No track is currently playing.', 'error');
                            return;
                        }

                        try {
                            const checkResponse = await fetch('/checkTrackExists', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ trackUri: actionTrack.uri })
                            });
                            const result = await checkResponse.json().catch(() => ({}));
                            if (!result.exists) {
                                Notify('This song has left the queue and can no longer be shielded.');
                                return;
                            }

                            if (typeof window.purchaseShield === 'function') {
                                window.purchaseShield(actionTrack.uri, actionTrack.addedAt || 0);
                            } else {
                                Notify('Unable to purchase shield.', 'error');
                            }
                        } catch (err) {
                            console.error('Error checking track for shield:', err);
                            Notify('Unable to verify track status', 'error');
                        }
                    });

                    // Real-time ban/unban via WebSocket
                    socket.on('userBanned', (data) => {
                        if (data.userId == currentID) {
                            userIsBanned = true;
                            showBanBanner();
                            Notify('You have been banned from Jukebar by your teacher.', 'error');
                        }
                    });

                    socket.on('userUnbanned', (data) => {
                        if (data.userId == currentID) {
                            userIsBanned = false;
                            const banner = document.getElementById('ban-banner');
                            if (banner) banner.remove();
                            Notify('You have been unbanned! You can use Jukebar again.', 'success');
                        }
                    });

                    socket.on('auxiliaryPermission', (permission) => {
                        if (permission <= userPermission) {
                            useJukebar = true;
                        } else {
                            useJukebar = false;
                        }
                    });

                    // Update online user count
                    socket.on('userCount', (count) => {
                        const countElement = document.getElementById('onlineUserCount');
                        if (countElement) {
                            countElement.textContent = count;
                        }
                    });

                    function handleSearchSubmit(event) {
                        event.preventDefault();
                        searchSpotify();
                    }

                    async function checkPaymentAndPlay(uri, trackMeta = {}) {
                        // Check if user is banned
                        if (userIsBanned) {
                            Notify('You have been banned from Jukebar. Contact your teacher.', 'error');
                            return;
                        }

                        // Check if Jukebar is enabled
                        if (!useJukebar) {
                            Notify('Jukebar is currently disabled by your teacher.', 'error');
                            return;
                        }

                        if (isOwnerClient(currentID)) {
                            const anonMode = document.getElementById('owner-anon-mode')?.checked || false;
                            addToQueue(uri, anonMode, trackMeta);
                            return;
                        }

                        if (!hasPaid) {
                            pendingTrackUri = uri;
                            pendingTrackMeta = trackMeta;
                            pendingAction = 'play';
                            showPayment();
                            return;
                        }

                        // Reset payment flag after using it
                        hasPaid = false;
                        addToQueue(uri, null, trackMeta);
                    }

                    async function checkPaymentAndSkip() {
                        console.log('⏭️ Skip clicked - currentlyPlayingUri:', currentlyPlayingUri);

                        // Check if user is banned
                        if (userIsBanned) {
                            Notify('You have been banned from Jukebar. Contact your teacher.', 'error');
                            return;
                        }

                        // Check if Jukebar is enabled
                        if (!useJukebar) {
                            Notify('Jukebar is currently disabled by your teacher.', 'error');
                            return;
                        }

                        // Build the full URI - add prefix only if not already present
                        let skipUri = currentlyPlayingUri;
                        if (currentlyPlayingUri && !currentlyPlayingUri.startsWith('spotify:track:')) {
                            skipUri = `spotify:track:${currentlyPlayingUri}`;
                        }

                        console.log('⏭️ Final skipUri:', skipUri);

                        if (isOwnerClient(currentID)) {
                            skip(skipUri);
                            return;
                        }

                        if (!hasPaid) {
                            pendingTrackUri = skipUri;
                            pendingAction = 'skip';
                            showPayment();
                            return;
                        }

                        // Reset payment flag after using it
                        hasPaid = false;
                        skip(skipUri);
                    }

                    async function skip(uri) {
                        try {
                            const response = await fetch('/skip', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ uri })
                            });

                            const data = await response.json();

                            if (data.shieldBlocked) {
                                // Skip was blocked by a shield
                                Notify(data.message || 'Skip blocked by shield!', 'error', '/img/skipShield.png');
                                // Request queue update to show updated shield count
                                socket.emit('getQueue');
                            } else if (data.ok) {
                                // Skip succeeded
                                Notify('Track skipped!', 'success');
                            } else {
                                // Other error
                                Notify(data.error || 'Failed to skip', 'error');
                                refund();
                            }
                        } catch (error) {
                            console.error('Error skipping track:', error);
                            Notify('Network error', 'error');
                        }
                    }

                    function addToQueue(uri, anonMode = null, trackMeta = {}) {
                        if (anonMode === null) {
                            anonMode = document.getElementById('anonMode')?.checked || false;
                        }
                        fetch('/addToQueue', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ uri, anonMode, trackName: trackMeta.name || '', trackArtist: trackMeta.artist || '', trackImage: trackMeta.image || '' })
                        })
                            .then(response => {
                                if (response.ok) {
                                    Notify('Track added to queue!', 'success');
                                } else {
                                    return response.json().then(data => {
                                        Notify(data.error || 'Failed to add track to queue', 'error');
                                        refund();
                                    });
                                }
                            })
                            .catch(error => {
                                //console.log('oopsies!')
                                console.error('Error adding track to queue:', error);
                                Notify('Network error', 'error');
                            });
                    }

                    let searchNextOffset = 0;
                    let searchCurrentQuery = '';
                    let currentSearchResults = { tracks: [], artists: [], albums: [] };
                    let activeSearchFilter = 'all';
                    let searchHasMore = false;
                    const SEARCH_SUBMIT_COOLDOWN_MS = 700;
                    let mainSearchInFlight = false;
                    let mainSearchLastAt = 0;
                    let createPlaylistSearchInFlight = false;
                    let createPlaylistSearchLastAt = 0;
                    let addSongSearchInFlight = false;
                    let addSongSearchLastAt = 0;

                    async function logRecentlyQueuedInteraction(type, payload) {
                        try {
                            await fetch('/recentlyQueued/interactions', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    type,
                                    id: payload?.id || '',
                                    name: payload?.name || '',
                                    subtitle: payload?.subtitle || '',
                                    image: payload?.image || ''
                                })
                            });
                        } catch (error) {
                            console.warn('Failed to log recently queued interaction:', error);
                        }
                    }

                    function renderArtistResults(artists, resultsDiv) {
                        if (!artists || artists.length === 0) return;
                        artists.forEach(artist => {
                            const div = document.createElement('div');
                            div.className = 'search-result-item artist-result-item';
                            div.dataset.itemType = 'artist';
                            div.dataset.artistId = artist.id;
                            div.dataset.artistName = artist.name;
                            div.dataset.artistImage = artist.image || '';
                            div.innerHTML = `
                                ${artist.image
                                    ? `<img src="${artist.image}" alt="${escapeHtml(artist.name)}" class="album-cover artist-cover" />`
                                    : `<div class="album-cover artist-cover" style="background:#282828;display:flex;align-items:center;justify-content:center;font-size:2em;">🎤</div>`
                                }
                                <div class="search-result-content-outer">
                                    <div class="thebackgroundoftheitemsthatareinthesearchresults"></div>
                                    <div class="search-result-content-pushies">
                                        <span class="artist-badge">ARTIST</span>
                                        <div class="search-result-title" title="${escapeHtml(artist.name)}">${escapeHtml(artist.name)}</div>
                                    </div>
                                </div>
                            `;
                            resultsDiv.appendChild(div);
                        });
                    }

                    function isFourDigitYear(value) {
                        return /^\d{4}$/.test((value || '').trim());
                    }

                    function normalizeAlbumMeta(subtitleValue, releaseYearValue) {
                        const rawSubtitle = (subtitleValue || '').trim();
                        let year = (releaseYearValue || '').trim();
                        let artist = '';

                        if (rawSubtitle) {
                            const parts = rawSubtitle.split(' · ').map(p => p.trim()).filter(Boolean);
                            const yearParts = parts.filter(isFourDigitYear);
                            if (!year && yearParts.length > 0) year = yearParts[yearParts.length - 1];
                            const artistParts = parts.filter(p => !isFourDigitYear(p));
                            artist = artistParts.join(' · ').trim();
                        }

                        if (isFourDigitYear(artist)) artist = '';
                        if (artist && year && artist === year) artist = '';

                        const display = `${artist}${year ? (artist ? ' · ' : '') + year : ''}`;
                        return { artist, year, display };
                    }

                    function renderAlbumSearchResults(albums, resultsDiv) {
                        if (!albums || albums.length === 0) return;
                        albums.forEach(album => {
                            const div = document.createElement('div');
                            div.className = 'search-result-item album-result-item';
                            div.dataset.itemType = 'album';
                            div.dataset.albumId = album.id || '';
                            div.dataset.albumName = album.name || '';
                            div.dataset.albumImage = album.image || '';
                            const albumArtists = Array.isArray(album.artists)
                                ? album.artists.map(a => (typeof a === 'string' ? a : a?.name)).filter(Boolean).join(', ')
                                : (album.artists || album.artist || '');
                            const year = album.release_date ? album.release_date.substring(0, 4) : '';
                            div.dataset.albumYear = year;
                            div.dataset.albumArtists = albumArtists;
                            div.innerHTML = `
                                ${album.image
                                    ? `<img src="${album.image}" alt="${escapeHtml(album.name)}" class="album-cover" />`
                                    : `<div class="album-cover" style="background:#282828;"></div>`
                                }
                                <div class="search-result-content-outer">
                                    <div class="thebackgroundoftheitemsthatareinthesearchresults"></div>
                                    <div class="search-result-content-pushies">
                                        <span class="album-badge">ALBUM</span>
                                        <div class="search-result-title" title="${escapeHtml(album.name)}">${escapeHtml(album.name)}</div>
                                        <div class="search-result-artist">${escapeHtml(albumArtists)}${year ? ' · ' + year : ''}</div>
                                    </div>
                                </div>
                            `;
                            resultsDiv.appendChild(div);
                        });
                    }

                    function renderSearchResults(tracks, resultsDiv) {
                        tracks.forEach(track => {
                            const trackDiv = document.createElement('div');
                            trackDiv.className = 'search-result-item';
                            trackDiv.innerHTML = `
                        ${track.album.image ? `<img src="${track.album.image}" alt="${track.album.name || ''}" class="album-cover" />` : `<div class="album-cover" style="background:#282828;border-radius:4px;flex-shrink:0;"></div>`}
                        <div class="search-result-content-outer">
                            <div class="thebackgroundoftheitemsthatareinthesearchresults"></div>
                            <div class="search-result-content-pushies">
                                <div class="search-result-title" title="${track.name}">${track.name}</div>
                                <div class="search-result-artist" title="${track.artist}">${track.artist}</div>
                                <div class="search-result-actions">
                                    <button class="play-button-icon" data-uri="${track.uri}" data-name="${track.name.replace(/"/g, '&quot;')}" data-artist="${track.artist.replace(/"/g, '&quot;')}" data-image="${track.album.image || ''}" title="Add to queue">
                                        <img src="/img/play.png" alt="Play" class="play-icon">
                                    </button>
                                    <button class="ban-button-icon" data-uri="${track.uri}" data-name="${track.name.replace(/"/g, '&quot;')}" data-artist="${track.artist.replace(/"/g, '&quot;')}" data-image="${track.album.image || ''}" title="Vote to ban">
                                        <img src="/img/ban.png" alt="Ban" class="ban-icon">
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                            resultsDiv.appendChild(trackDiv);
                        });
                    }

                    function renderRecentlyQueuedItems(items, resultsDiv) {
                        items.forEach(item => {
                            const itemType = item.itemType || 'track';

                            if (itemType === 'artist') {
                                const artistDiv = document.createElement('div');
                                artistDiv.className = 'search-result-item artist-result-item';
                                artistDiv.dataset.uri = item.uri;
                                artistDiv.dataset.itemType = 'artist';
                                const artistId = (item.uri || '').split(':')[2] || '';
                                artistDiv.dataset.artistId = artistId;
                                artistDiv.dataset.artistName = item.name || '';
                                artistDiv.dataset.artistImage = item.album?.image || '';
                                const subtitle = (item.artist && item.artist !== 'Unknown')
                                    ? item.artist
                                    : ((item.subtitle && item.subtitle !== 'Unknown') ? item.subtitle : '');
                                artistDiv.innerHTML = `
                                    ${item.album?.image
                                        ? `<img src="${item.album.image}" alt="${escapeHtml(item.name)}" class="album-cover artist-cover" />`
                                        : `<div class="album-cover artist-cover" style="background:#282828;display:flex;align-items:center;justify-content:center;font-size:2em;">🎤</div>`
                                    }
                                    <div class="search-result-content-outer">
                                        <div class="thebackgroundoftheitemsthatareinthesearchresults"></div>
                                        <div class="search-result-content-pushies">
                                            <span class="artist-badge">ARTIST</span>
                                            <div class="search-result-title" title="${escapeHtml(item.name)}">${escapeHtml(item.name)}</div>
                                            <div class="search-result-artist">${escapeHtml(subtitle)}</div>
                                        </div>
                                    </div>
                                `;
                                resultsDiv.appendChild(artistDiv);
                                return;
                            }

                            if (itemType === 'album') {
                                const albumDiv = document.createElement('div');
                                albumDiv.className = 'search-result-item album-result-item';
                                albumDiv.dataset.uri = item.uri;
                                albumDiv.dataset.itemType = 'album';
                                const albumId = (item.uri || '').split(':')[2] || '';
                                albumDiv.dataset.albumId = albumId;
                                albumDiv.dataset.albumName = item.name || '';
                                albumDiv.dataset.albumImage = item.album?.image || '';
                                albumDiv.dataset.albumYear = item.releaseYear || '';
                                const rawSubtitle = (item.artist && item.artist !== 'Unknown')
                                    ? item.artist
                                    : ((item.subtitle && item.subtitle !== 'Unknown') ? item.subtitle : '');
                                const normalizedMeta = normalizeAlbumMeta(rawSubtitle, item.releaseYear || '');
                                const subtitle = normalizedMeta.display;
                                const subtitleIsYearOnly = isFourDigitYear((subtitle || '').trim());
                                albumDiv.dataset.albumArtists = normalizedMeta.artist;
                                albumDiv.dataset.albumYear = normalizedMeta.year;
                                albumDiv.innerHTML = `
                                    ${item.album?.image
                                        ? `<img src="${item.album.image}" alt="${escapeHtml(item.name)}" class="album-cover" />`
                                        : `<div class="album-cover" style="background:#282828;"></div>`
                                    }
                                    <div class="search-result-content-outer">
                                        <div class="thebackgroundoftheitemsthatareinthesearchresults"></div>
                                        <div class="search-result-content-pushies">
                                            <span class="album-badge">ALBUM</span>
                                            <div class="search-result-title" title="${escapeHtml(item.name)}">${escapeHtml(item.name)}</div>
                                            <div class="search-result-artist" data-album-meta="true">${escapeHtml(subtitle)}</div>
                                        </div>
                                    </div>
                                `;
                                resultsDiv.appendChild(albumDiv);

                                // Older history rows can contain only the year (e.g., "1982").
                                // Backfill artist text from album tracks so cards read "Artist · Year".
                                if (subtitleIsYearOnly && albumId) {
                                    fetch(`/api/album/${albumId}/tracks`)
                                        .then(r => r.json())
                                        .then(data => {
                                            if (!data?.ok || !Array.isArray(data.tracks) || data.tracks.length === 0) return;
                                            const primaryArtist = (data.tracks[0]?.artist || '').trim();
                                            if (!primaryArtist) return;
                                            const yearOnly = (normalizedMeta.year || '').trim();
                                            const enrichedSubtitle = `${primaryArtist}${yearOnly ? ' · ' + yearOnly : ''}`;
                                            albumDiv.dataset.albumArtists = primaryArtist;
                                            if (yearOnly) albumDiv.dataset.albumYear = yearOnly;
                                            const metaEl = albumDiv.querySelector('[data-album-meta="true"]');
                                            if (metaEl) metaEl.textContent = enrichedSubtitle;
                                        })
                                        .catch(() => {
                                            // Non-fatal: keep existing subtitle if enrichment fails.
                                        });
                                }
                                return;
                            }

                            renderSearchResults([item], resultsDiv);
                        });
                    }

                    function removeLoadMoreButton() {
                        document.getElementById('loadMoreBtn')?.remove();
                    }

                    function addLoadMoreButton(resultsDiv) {
                        removeLoadMoreButton();
                        const btn = document.createElement('button');
                        btn.id = 'loadMoreBtn';
                        btn.className = 'load-more-btn';
                        btn.textContent = 'Load More';
                        btn.addEventListener('click', () => loadMoreResults());
                        resultsDiv.appendChild(btn);
                    }

                    async function loadMoreResults() {
                        if (!searchCurrentQuery || searchNextOffset <= 0) return;
                        const btn = document.getElementById('loadMoreBtn');
                        if (btn) { btn.textContent = 'Loading...'; btn.disabled = true; }

                        try {
                            const response = await fetch('/search', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ query: searchCurrentQuery, offset: searchNextOffset })
                            });
                            const data = await response.json();
                            if (!response.ok || data.ok === false) {
                                if (btn) { btn.textContent = 'Load More'; btn.disabled = false; }
                                return;
                            }

                            const resultsDiv = document.getElementById('searchResults');
                            removeLoadMoreButton();

                            // Always advance pagination from the server. A page can return 0 tracks after
                            // explicit/long/banned filtering while Spotify still has more raw results —
                            // otherwise the button vanished and offset never advanced.
                            searchNextOffset = typeof data.nextOffset === 'number' ? data.nextOffset : searchNextOffset;
                            searchHasMore = !!data.hasMore;

                            const newItems = (data.tracks && data.tracks.items) ? data.tracks.items : [];
                            if (newItems.length > 0) {
                                currentSearchResults.tracks = currentSearchResults.tracks.concat(newItems);
                                renderSearchResults(newItems, resultsDiv);
                            }

                            if (searchHasMore) {
                                addLoadMoreButton(resultsDiv);
                            }
                        } catch (error) {
                            console.error('Error loading more results:', error);
                            if (btn) { btn.textContent = 'Load More'; btn.disabled = false; }
                        }
                    }

                    function applySearchFilter(filter) {
                        activeSearchFilter = filter;
                        document.querySelectorAll('.search-filter-tab').forEach(btn => {
                            btn.classList.toggle('active', btn.dataset.filter === filter);
                        });

                        const resultsDiv = document.getElementById('searchResults');
                        resultsDiv.innerHTML = '';

                        const showAll = filter === 'all';

                        if ((showAll || filter === 'artists') && currentSearchResults.artists.length > 0) {
                            renderArtistResults(currentSearchResults.artists, resultsDiv);
                        }

                        if ((showAll || filter === 'albums') && currentSearchResults.albums.length > 0) {
                            renderAlbumSearchResults(currentSearchResults.albums, resultsDiv);
                        }

                        if ((showAll || filter === 'songs') && currentSearchResults.tracks.length > 0) {
                            renderSearchResults(currentSearchResults.tracks, resultsDiv);
                            if (searchHasMore) addLoadMoreButton(resultsDiv);
                        }

                        if (resultsDiv.children.length === 0) {
                            resultsDiv.innerHTML = '<p style="color:#b3b3b3;padding:8px 0;">No results for this filter.</p>';
                        }
                    }

                    async function searchSpotify() {
                        const now = Date.now();
                        if (mainSearchInFlight || (now - mainSearchLastAt) < SEARCH_SUBMIT_COOLDOWN_MS) return;
                        const query = document.getElementById('searchInput').value;
                        if (!query) return;
                        mainSearchInFlight = true;
                        mainSearchLastAt = now;
                        searchCurrentQuery = query;
                        activeSearchFilter = 'all';

                        try {
                            const response = await fetch('/search', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ query, offset: 0, includeArtists: true, includeAlbums: true })
                            });
                            const data = await response.json();
                            if (!response.ok || data.ok === false) {
                                const tabsEl = document.getElementById('searchFilterTabs');
                                tabsEl.style.display = 'none';
                                document.getElementById('searchResults').innerHTML =
                                    `<p style="color:#ff8a8a;padding:8px 0;">${escapeHtml(data.error || 'Search failed. Please try again.')}</p>`;
                                return;
                            }

                            currentSearchResults = {
                                tracks: data.tracks?.items || [],
                                artists: data.artists || [],
                                albums: data.albums || []
                            };
                            searchNextOffset = data.nextOffset || 0;
                            searchHasMore = !!data.hasMore;

                            const hasAny = currentSearchResults.tracks.length > 0 ||
                                           currentSearchResults.artists.length > 0 ||
                                           currentSearchResults.albums.length > 0;

                            const tabsEl = document.getElementById('searchFilterTabs');
                            if (hasAny) {
                                tabsEl.style.display = '';
                                // Reset to "All" tab on new search
                                document.querySelectorAll('.search-filter-tab').forEach(btn => {
                                    btn.classList.toggle('active', btn.dataset.filter === 'all');
                                });
                                applySearchFilter('all');
                            } else {
                                tabsEl.style.display = 'none';
                                document.getElementById('searchResults').innerHTML = '<p>No clean tracks found.</p>';
                            }
                        } catch (error) {
                            console.error('Error searching Spotify:', error);
                        } finally {
                            mainSearchInFlight = false;
                        }
                    }

                    // =============================================
                    // Artist Modal
                    // =============================================
                    let currentArtistId = null;
                    let currentArtistName = null;
                    let directAlbumMode = false;
                    let albumsNextOffset = 0;
                    let albumsHasMore = false;

                    function openArtistModal(artistId, artistName, artistImage) {
                        currentArtistId = artistId;
                        currentArtistName = artistName;
                        albumsNextOffset = 0;
                        albumsHasMore = false;

                        // Render header
                        const header = document.getElementById('artistModalHeader');
                        header.innerHTML = `
                            <div class="artist-modal-hero">
                                ${artistImage
                                    ? `<img src="${artistImage}" alt="${escapeHtml(artistName)}" class="artist-modal-avatar" />`
                                    : `<div class="artist-modal-avatar artist-modal-avatar--placeholder">🎤</div>`
                                }
                                <div class="artist-modal-hero-info">
                                    <div class="artist-modal-name">${escapeHtml(artistName)}</div>
                                </div>
                            </div>
                        `;

                        // Show header + overview, hide album detail
                        document.getElementById('artistModalHeader').style.display = '';
                        document.getElementById('artistOverviewView').style.display = '';
                        document.getElementById('albumDetailView').style.display = 'none';

                        // Show loading states
                        document.getElementById('artistTopTracksList').innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">Loading...</p>';
                        document.getElementById('artistAlbumGrid').innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">Loading...</p>';

                        document.getElementById('artistModal').style.display = 'flex';
                        window.refreshModalBlurState();

                        // Fetch top tracks and albums in parallel
                        Promise.all([
                            fetch(`/api/artist/${artistId}/top-tracks?name=${encodeURIComponent(artistName)}`).then(r => r.json()),
                            fetch(`/api/artist/${artistId}/albums`).then(r => r.json())
                        ]).then(([topTracksData, albumsData]) => {
                            renderArtistTopTracks(topTracksData);
                            renderArtistAlbums(albumsData);
                        }).catch(err => {
                            console.error('Error loading artist data:', err);
                            document.getElementById('artistTopTracksList').innerHTML = '<p style="color:#ff5555;text-align:center;padding:8px;">Failed to load tracks.</p>';
                            document.getElementById('artistAlbumGrid').innerHTML = '<p style="color:#ff5555;text-align:center;padding:8px;">Failed to load albums.</p>';
                        });
                    }

                    function closeArtistModal() {
                        document.getElementById('artistModal').style.display = 'none';
                        window.refreshModalBlurState();
                        currentArtistId = null;
                        currentArtistName = null;
                        directAlbumMode = false;
                    }

                    function renderArtistTopTracks(data) {
                        const container = document.getElementById('artistTopTracksList');
                        if (!data.ok || !data.tracks || data.tracks.length === 0) {
                            container.innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">No clean tracks found.</p>';
                            return;
                        }
                        container.innerHTML = '';
                        data.tracks.forEach((track, idx) => {
                            const div = document.createElement('div');
                            div.className = 'artist-track-row';
                            div.innerHTML = `
                                <span class="artist-track-num">${idx + 1}</span>
                                ${track.album.image
                                    ? `<img src="${track.album.image}" alt="" class="artist-track-img" />`
                                    : `<div class="artist-track-img artist-track-img--placeholder"></div>`
                                }
                                <div class="artist-track-info">
                                    <div class="artist-track-name" title="${escapeHtml(track.name)}">${escapeHtml(track.name)}</div>
                                    <div class="artist-track-album" title="${escapeHtml(track.album.name)}">${escapeHtml(track.album.name)}</div>
                                </div>
                                <div class="artist-track-duration">${formatDuration(track.duration_ms)}</div>
                                <button class="play-button-icon artist-track-queue-btn"
                                    data-uri="${track.uri}"
                                    data-name="${escapeHtml(track.name)}"
                                    data-artist="${escapeHtml(track.artist)}"
                                    data-image="${track.album.image || ''}"
                                    title="Add to queue">
                                    <img src="/img/play.png" alt="Queue" class="play-icon">
                                </button>
                            `;
                            div.querySelector('.artist-track-queue-btn').addEventListener('click', function () {
                                checkPaymentAndPlay(this.dataset.uri, { name: this.dataset.name, artist: this.dataset.artist, image: this.dataset.image });
                            });
                            container.appendChild(div);
                        });
                    }

                    function renderArtistAlbums(data, append = false) {
                        const container = document.getElementById('artistAlbumGrid');

                        if (!append) container.innerHTML = '';

                        if (!data.ok || !data.albums || data.albums.length === 0) {
                            if (!append) container.innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">No albums available.</p>';
                            return;
                        }

                        // Remove existing Load More button before appending new cards
                        container.querySelector('.artist-albums-load-more')?.remove();

                        data.albums.forEach(album => {
                            const card = document.createElement('div');
                            card.className = 'artist-album-card';
                            const year = album.release_date ? album.release_date.substring(0, 4) : '';
                            card.innerHTML = `
                                ${album.image
                                    ? `<img src="${album.image}" alt="${escapeHtml(album.name)}" class="artist-album-cover" />`
                                    : `<div class="artist-album-cover artist-album-cover--placeholder"></div>`
                                }
                                <div class="artist-album-name" title="${escapeHtml(album.name)}">${escapeHtml(album.name)}</div>
                                <div class="artist-album-meta">${escapeHtml(album.album_type)} ${year ? '· ' + year : ''}</div>
                            `;
                            card.addEventListener('click', () => {
                                logRecentlyQueuedInteraction('album', {
                                    id: album.id,
                                    name: album.name,
                                    subtitle: `${album.album_type || 'album'}${year ? ' · ' + year : ''}`,
                                    image: album.image || ''
                                });
                                openAlbumDetail(album.id, album.name, album.image, year);
                            });
                            container.appendChild(card);
                        });

                        albumsNextOffset = data.nextOffset || 0;
                        albumsHasMore = !!data.hasMore;

                        if (albumsHasMore) {
                            const btn = document.createElement('button');
                            btn.className = 'load-more-btn artist-albums-load-more';
                            btn.textContent = 'Load More';
                            btn.addEventListener('click', loadMoreAlbums);
                            container.appendChild(btn);
                        }
                    }

                    async function loadMoreAlbums() {
                        if (!currentArtistId || !albumsHasMore) return;
                        const btn = document.querySelector('.artist-albums-load-more');
                        if (btn) { btn.textContent = 'Loading...'; btn.disabled = true; }
                        try {
                            const data = await fetch(`/api/artist/${currentArtistId}/albums?offset=${albumsNextOffset}`).then(r => r.json());
                            renderArtistAlbums(data, true);
                        } catch (err) {
                            console.error('Error loading more albums:', err);
                            if (btn) { btn.textContent = 'Load More'; btn.disabled = false; }
                        }
                    }

                    function formatDuration(ms) {
                        if (!ms) return '';
                        const totalSec = Math.floor(ms / 1000);
                        const min = Math.floor(totalSec / 60);
                        const sec = totalSec % 60;
                        return `${min}:${sec.toString().padStart(2, '0')}`;
                    }

                    async function openAlbumDetail(albumId, albumName, albumImage, albumYear) {
                        document.getElementById('artistModalHeader').style.display = 'none';
                        document.getElementById('artistOverviewView').style.display = 'none';
                        document.getElementById('albumDetailView').style.display = '';

                        let resolvedAlbumYear = (albumYear || '').trim();
                        let resolvedAlbumArtist = '';
                        const header = document.getElementById('albumDetailHeader');
                        const renderAlbumHeader = () => {
                            header.innerHTML = `
                                <div class="album-detail-hero">
                                    ${albumImage
                                        ? `<img src="${albumImage}" alt="${escapeHtml(albumName)}" class="album-detail-cover" />`
                                        : `<div class="album-detail-cover album-detail-cover--placeholder"></div>`
                                    }
                                    <div class="album-detail-info">
                                        <div class="album-detail-name">${escapeHtml(albumName)}</div>
                                        ${resolvedAlbumArtist ? `<div class="album-detail-artist">${escapeHtml(resolvedAlbumArtist)}</div>` : ''}
                                        ${resolvedAlbumYear ? `<div class="album-detail-year">${escapeHtml(resolvedAlbumYear)}</div>` : ''}
                                    </div>
                                </div>
                                <hr class="album-detail-divider">
                            `;
                        };
                        renderAlbumHeader();

                        const tracksList = document.getElementById('albumDetailTracksList');
                        tracksList.innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">Loading tracks...</p>';

                        try {
                            const tracksData = await fetch(`/api/album/${albumId}/tracks`).then(r => r.json());
                            if (!resolvedAlbumArtist && tracksData?.tracks?.length > 0) {
                                resolvedAlbumArtist = String(tracksData.tracks[0]?.artist || '').trim();
                            }
                            if (!resolvedAlbumYear && tracksData?.releaseYear) {
                                resolvedAlbumYear = String(tracksData.releaseYear).trim();
                            }
                            renderAlbumHeader();

                            if (!tracksData.ok || !tracksData.tracks || tracksData.tracks.length === 0) {
                                tracksList.innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">No clean tracks found in this album.</p>';
                                return;
                            }

                            tracksList.innerHTML = '';
                            tracksData.tracks.forEach((track, idx) => {
                                const div = document.createElement('div');
                                div.className = 'artist-track-row';
                                div.innerHTML = `
                                    <span class="artist-track-num">${idx + 1}</span>
                                    <div class="artist-track-info" style="flex:1;">
                                        <div class="artist-track-name" title="${escapeHtml(track.name)}">${escapeHtml(track.name)}</div>
                                        <div class="artist-track-album">${escapeHtml(track.artist)}</div>
                                    </div>
                                    <div class="artist-track-duration">${formatDuration(track.duration_ms)}</div>
                                    <button class="play-button-icon artist-track-queue-btn"
                                        data-uri="${track.uri}"
                                        data-name="${escapeHtml(track.name)}"
                                        data-artist="${escapeHtml(track.artist)}"
                                        data-image="${track.album.image || ''}"
                                        title="Add to queue">
                                        <img src="/img/play.png" alt="Queue" class="play-icon">
                                    </button>
                                `;
                                div.querySelector('.artist-track-queue-btn').addEventListener('click', function () {
                                    checkPaymentAndPlay(this.dataset.uri, { name: this.dataset.name, artist: this.dataset.artist, image: this.dataset.image });
                                });
                                tracksList.appendChild(div);
                            });
                        } catch (err) {
                            console.error('Error loading album details:', err);
                            tracksList.innerHTML = '<p style="color:#ff5555;text-align:center;padding:8px;">Failed to load album tracks.</p>';
                        }
                    }

                    function showArtistOverview() {
                        if (directAlbumMode) {
                            directAlbumMode = false;
                            closeArtistModal();
                            return;
                        }
                        document.getElementById('albumDetailView').style.display = 'none';
                        document.getElementById('artistModalHeader').style.display = '';
                        document.getElementById('artistOverviewView').style.display = '';
                    }

                    function openAlbumDirect(albumId, albumName, albumImage, albumYear) {
                        directAlbumMode = true;
                        currentArtistId = null;
                        currentArtistName = null;

                        // Hide artist header and overview; show album detail
                        const directModalHeader = document.getElementById('artistModalHeader');
                        if (directModalHeader) directModalHeader.innerHTML = '';

                        document.getElementById('artistModal').style.display = 'flex';
                        window.refreshModalBlurState();

                        openAlbumDetail(albumId, albumName, albumImage, albumYear);
                    }

                    // Wire up search filter tabs
                    document.querySelectorAll('.search-filter-tab').forEach(btn => {
                        btn.addEventListener('click', () => applySearchFilter(btn.dataset.filter));
                    });

                    // Wire up artist modal close button — context-aware:
                    // if inside an album detail (from artist overview), go back; otherwise close.
                    document.getElementById('artistModalClose')?.addEventListener('click', () => {
                        const albumView = document.getElementById('albumDetailView');
                        if (!directAlbumMode && albumView && albumView.style.display !== 'none') {
                            showArtistOverview();
                        } else {
                            closeArtistModal();
                        }
                    });
                    document.getElementById('artistModal')?.addEventListener('click', function (e) {
                        if (e.target === this) closeArtistModal();
                    });

                    async function loadRecentlyQueued() {
                        try {
                            const response = await fetch('/recentlyQueued');
                            const data = await response.json();
                            const resultsDiv = document.getElementById('searchResults');

                            if (!resultsDiv || resultsDiv.children.length > 0) return;

                            if (data.ok && data.tracks.length > 0) {
                                const header = document.createElement('div');
                                header.className = 'recently-queued-header';
                                header.style.display = 'flex';
                                header.style.justifyContent = 'space-between';
                                header.style.alignItems = 'center';

                                const titleSpan = document.createElement('span');
                                titleSpan.textContent = 'Recently Viewed';
                                header.appendChild(titleSpan);

                                const clearLink = document.createElement('a');
                                clearLink.textContent = 'Clear History';
                                clearLink.href = '#';
                                clearLink.style.cssText = 'font-size: 0.85em; color: rgba(255, 255, 255, 0.6); text-decoration: none; cursor: pointer; transition: color 0.2s;';
                                clearLink.onmouseover = () => clearLink.style.color = 'rgba(255, 255, 255, 0.9)';
                                clearLink.onmouseout = () => clearLink.style.color = 'rgba(255, 255, 255, 0.6)';
                                clearLink.onclick = (e) => {
                                    e.preventDefault();
                                    if (confirm('Are you sure you want to clear your history?')) {
                                        fetch('/clearQueueHistory', { method: 'POST' })
                                            .then(res => res.json())
                                            .then(data => {
                                                if (data.ok) {
                                                    Notify('History cleared', 'info');
                                                    loadRecentlyQueued(); // Reload
                                                } else {
                                                    Notify('Failed to clear history', 'error');
                                                }
                                            })
                                            .catch(err => {
                                                console.error('Error clearing history:', err);
                                                Notify('Error clearing history', 'error');
                                            });
                                    }
                                };
                                header.appendChild(clearLink);

                                resultsDiv.appendChild(header);
                                const recentDivider = document.createElement('hr');
                                recentDivider.className = 'recently-queued-divider';
                                resultsDiv.appendChild(recentDivider);
                                renderRecentlyQueuedItems(data.tracks, resultsDiv);
                            }

                        } catch (error) {
                            console.error('Error loading recently queued:', error);
                        }
                    }

                    async function getQueue() {
                        try {
                            const response = await fetch('/getQueue', {
                                method: 'GET',
                                headers: { 'Content-Type': 'application/json' }
                            });
                            const data = await response.json();
                            if (data.ok) {
                                const queueDiv = document.getElementById('queue');
                                queueDiv.innerHTML = '';
                                if (data.tracks.items.length == 0) {
                                    queueDiv.innerHTML = '<p>No tracks in queue.</p>';
                                } else {
                                    data.tracks.items.forEach((item, index) => {
                                        const itemDiv = document.createElement('div');
                                        itemDiv.className = 'queue-item';

                                        // Handle anonymous mode
                                        let addedByDisplay = item.addedBy;
                                        if (typeof addedByDisplay === 'object' || addedByDisplay === '[object Object]') {
                                            addedByDisplay = 'Spotify';
                                        }

                                        // Check if anonymous mode and user is not a teacher
                                        if ((item.isAnon === 1 || item.isAnon === true) && userPermission < 4) {
                                            addedByDisplay = 'Anonymous';
                                        }

                                        itemDiv.innerHTML = `
                                        ${item.album?.image ? `<img src="${item.album.image}" alt="${item.album.name || ''}" class="album-cover" />` : `<div class="album-cover" style="background:#282828;border-radius:4px;flex-shrink:0;"></div>`}
                                        <div class="queue-item-content">
                                            <div class="queue-item-title">${item.name}</div>
                                            <div class="queue-item-artist">${item.artist}</div>
                                            <div class="queue-item-added-by">Added by ${addedByDisplay || 'Spotify'}</div>
                                        </div>
                                    `;
                                        queueDiv.appendChild(itemDiv);
                                    });
                                }
                            } else {
                                console.error('Failed to get queue:', data.error);
                            }
                        } catch (error) {
                            console.error('Error fetching queue:', error);
                        }
                    }

                    async function currentlyPlaying() {
                        try {
                            const response = await fetch('/currentlyPlaying', {
                                method: 'GET',
                                headers: { 'Content-Type': 'application/json' }
                            });
                            const data = await response.json();
                            if (data.ok) {
                                //console.log('Currently Playing:', data.tracks.items);
                                const CurrentDiv = document.getElementById('currentlyPlaying');
                                CurrentDiv.innerHTML = '';
                                if (data.tracks.items.length == 0) {
                                    const CurrentDiv = document.getElementById('currentlyPlaying');
                                    CurrentDiv.innerHTML = '<p>No track is currently playing. Ask your teacher to start spotify</p>';
                                    currentlyPlayingUri = null;
                                }
                                else {
                                    data.tracks.items.forEach((item, index) => {
                                        const itemDiv = document.createElement('div');
                                        itemDiv.className = 'current-item';
                                        itemDiv.innerHTML = `
                                    ${item.album?.image ? `<img src="${item.album.image}" alt="${item.album.name || ''}" class="album-cover" />` : `<div class="album-cover" style="background:#282828;border-radius:4px;flex-shrink:0;"></div>`}
                                    <div class="current-item-content">
                                        <div class="current-item-title">${item.name}</div>
                                        <div class="current-item-artist">${item.artist}</div>
                                    </div>`;
                                        CurrentDiv.appendChild(itemDiv);
                                        currentlyPlayingUri = item.id
                                    });
                                }
                            } else {
                                console.error('Failed to get current track:', data.error);
                            }
                        } catch (error) {
                            console.error('Error fetching current track:', error);
                        }
                    }

                    window.isModalVisible = function (id) {
                        const el = document.getElementById(id);
                        return !!el && window.getComputedStyle(el).display !== 'none';
                    };

                    window.refreshModalBlurState = function () {
                        const shouldBlurMain =
                            window.isModalVisible('paymentModal') ||
                            window.isModalVisible('playlistPaymentModal') ||
                            window.isModalVisible('createPlaylistModal') ||
                            window.isModalVisible('customPlaylistTracksModal') ||
                            window.isModalVisible('addSongToPlaylistModal') ||
                            window.isModalVisible('ownerShieldModal') ||
                            window.isModalVisible('artistModal');

                        const shouldBlurBottomBar =
                            window.isModalVisible('createPlaylistModal') ||
                            window.isModalVisible('customPlaylistTracksModal') ||
                            window.isModalVisible('addSongToPlaylistModal') ||
                            window.isModalVisible('ownerShieldModal') ||
                            window.isModalVisible('artistModal');

                        document.querySelector('.main-content')?.classList.toggle('blurred', shouldBlurMain);
                        document.querySelector('.player-bottom-bar')?.classList.toggle('blurred', shouldBlurBottomBar);
                    };

                    function showPayment() {
                        document.getElementById('paymentModal').style.display = 'block';
                        window.refreshModalBlurState();
                        // Reset shield quantity on open
                        if (pendingAction === 'Skip Shield') {
                            const input = document.getElementById('shield-quantity-input');
                            if (input) { input.value = ''; pendingShieldQuantity = 1; }
                        }
                        // Trigger getPrice via custom event
                        window.dispatchEvent(new CustomEvent('updatePrice', { detail: { pendingAction } }));
                    }

                    // Expose showPayment globally for external event handlers
                    window.showPayment = showPayment;

                    function hidePayment() {
                        document.getElementById('paymentModal').style.display = 'none';
                        window.refreshModalBlurState();
                        window.dispatchEvent(new CustomEvent('paymentHidden'));
                    }

                    function onPaymentSuccess() {
                        hasPaid = true;
                        hidePayment();

                        // Directly trigger the pending action now that payment is confirmed
                        const action = pendingAction;
                        pendingAction = null;

                        if (action === 'play' && pendingTrackUri) {
                            const uri = pendingTrackUri;
                            const meta = pendingTrackMeta || {};
                            pendingTrackUri = null;
                            pendingTrackMeta = {};
                            checkPaymentAndPlay(uri, meta);
                        } else if (action === 'skip') {
                            checkPaymentAndSkip();
                        } else if (action === 'Skip Shield' && pendingTrackUri) {
                            const uri = pendingTrackUri;
                            const addedAt = pendingTrackAddedAt || 0;
                            const qty = pendingShieldQuantity || 1;  // NEW
                            pendingTrackUri = null;
                            pendingTrackAddedAt = null;
                            pendingShieldQuantity = 1; // reset
                            purchaseShieldAfterPayment(uri, addedAt, qty);
                        } else if (action === 'Ban Vote' && pendingTrackUri) {
                            const uri = pendingTrackUri;
                            const trackName = pendingTrackName || 'Unknown Track';
                            const trackArtist = pendingTrackArtist || 'Unknown Artist';
                            const reason = pendingBanReason || 'student ban';
                            const banImage = pendingTrackMeta?.image || '';
                            pendingTrackUri = null;
                            pendingTrackName = null;
                            pendingTrackArtist = null;
                            pendingBanReason = null;
                            pendingTrackMeta = {};
                            startBanVote(uri, trackName, trackArtist, reason, banImage);
                        } else if (action === 'createPlaylist') {
                            finalizeCreatePlaylist();
                        } else if (action === 'addPlaylistSong' && pendingCustomPlaylistTrackUri) {
                            const uri = pendingCustomPlaylistTrackUri;
                            pendingCustomPlaylistTrackUri = null;
                            finalizeAddSongToPlaylist(uri);
                        } else if (action === 'removePlaylistSong' && pendingCustomPlaylistTrackUri) {
                            const uri = pendingCustomPlaylistTrackUri;
                            pendingCustomPlaylistTrackUri = null;
                            finalizeRemoveSongFromPlaylist(uri);
                        } else if (action === 'customPlaylistPlay' && pendingCustomPlaylistId) {
                            const playlistId = Number(pendingCustomPlaylistId);
                            pendingCustomPlaylistId = null;
                            pendingPlaylistId = null;
                            playCustomPlaylist(playlistId);
                        }
                    }

                    function refund() {
                        fetch('/refund', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ reason: "Jukebar refund" })
                        })
                            .then(response => response.json())
                            .then(data => {
                                if (data.ok) {
                                    Notify('Spotify error occurred. Your digipogs have been refunded.', 'success');
                                    //console.log('Refund successful:', data);
                                } else {
                                    Notify('Refund failed: ' + (data.error || 'Unknown error'), 'error');
                                    console.error('Refund failed:', data.error);
                                }
                            })
                            .catch(error => {
                                Notify('Network error during refund. Please contact support.', 'error');
                                console.error('Error during refund:', error);
                            });
                    }

                    // Wire up event listeners
                    document.getElementById('searchForm')?.addEventListener('submit', handleSearchSubmit);
                    document.getElementById('skip-button')?.addEventListener('click', checkPaymentAndSkip);
                    document.getElementById('hide-payment')?.addEventListener('click', hidePayment);
                    document.getElementById('close-notification')?.addEventListener('click', closeNotification);

                    // Playlist payment modal handlers
                    document.getElementById('playlist-pay-cancel')?.addEventListener('click', () => {
                        document.getElementById('playlistPaymentModal').style.display = 'none';
                        document.querySelector('.main-content').classList.remove('blurred');
                        selectedPlaylistQuote = null;
                    });

                    document.getElementById('playlist-pay-confirm')?.addEventListener('click', async () => {
                        if (!selectedPlaylistQuote?.playlistId) {
                            Notify('No playlist selected.', 'error');
                            return;
                        }

                        const pin = document.getElementById('playlist-pay-pin').value.trim();
                        if (!pin) {
                            Notify('Please enter your PIN.', 'error');
                            return;
                        }

                        const confirmBtn = document.getElementById('playlist-pay-confirm');
                        confirmBtn.disabled = true;

                        try {
                            if (document.getElementById('playlistSavePIN')?.checked) {
                                await fetch('/savePin', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ pin })
                                }).catch(() => { });
                            }

                            const reason = `Jukebar Payment - Play Playlist (${selectedPlaylistQuote.playlist?.name || 'Playlist'})`;
                            const transferRes = await fetch('/transfer', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    pin,
                                    reason,
                                    pendingAction: 'playlist',
                                    playlistId: selectedPlaylistQuote.playlistId
                                })
                            });
                            const transferData = await transferRes.json();
                            if (!transferRes.ok || !(transferData.ok || transferData.success || transferData.token)) {
                                throw new Error(transferData.error || 'Transfer failed');
                            }

                            // Payment succeeded — queue the playlist
                            const playlistId = selectedPlaylistQuote.playlistId;
                            document.getElementById('playlistPaymentModal').style.display = 'none';
                            document.querySelector('.main-content').classList.remove('blurred');
                            selectedPlaylistQuote = null;

                            await queuePlaylist(playlistId);
                        } catch (err) {
                            console.error('Playlist purchase error:', err);
                            Notify(err.message || 'Could not queue playlist', 'error');
                        } finally {
                            confirmBtn.disabled = false;
                        }
                    });

                    // Load saved PIN into playlist modal too
                    (async () => {
                        try {
                            const res = await fetch('/getPin', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' }
                            });
                            const data = await res.json();
                            if (data.ok && data.userPin) {
                                document.getElementById('playlist-pay-pin').value = data.userPin;
                                document.getElementById('playlistSavePIN').checked = true;
                            }
                        } catch (_) { }
                    })();

                    // When search input is cleared, restore recently queued
                    document.getElementById('searchInput')?.addEventListener('input', (e) => {
                        if (e.target.value.trim() === '') {
                            const searchResults = document.getElementById('searchResults');
                            if (searchResults) {
                                searchResults.innerHTML = '';
                            }
                            loadRecentlyQueued();
                        }
                    });

                    // Load recently queued songs on page load
                    loadRecentlyQueued();

                    // Owner shield modal
                    document.getElementById('owner-shield-close')?.addEventListener('click', () => {
                        document.getElementById('ownerShieldModal').style.display = 'none';
                        document.querySelector('.main-content').classList.remove('blurred');
                        pendingTrackUri = null;
                        pendingTrackAddedAt = null;
                        pendingShieldQuantity = 1;
                    });

                    document.getElementById('owner-shield-confirm')?.addEventListener('click', () => {
                        document.getElementById('ownerShieldModal').style.display = 'none';
                        document.querySelector('.main-content').classList.remove('blurred');
                        const uri = pendingTrackUri;
                        const addedAt = pendingTrackAddedAt || 0;
                        const qty = pendingShieldQuantity || 1;
                        pendingTrackUri = null;
                        pendingTrackAddedAt = null;
                        pendingShieldQuantity = 1;
                        purchaseShieldAfterPayment(uri, addedAt, qty);
                    });

                    // Changelog button event listeners
                    document.getElementById('changelog-button')?.addEventListener('click', () => {
                        document.getElementById('changelogModal').style.display = 'block';
                    });

                    document.getElementById('close-changelog')?.addEventListener('click', () => {
                        document.getElementById('changelogModal').style.display = 'none';
                        localStorage.setItem('changelog_seen', 'v2.0');
                    });

                    // Close modal when clicking outside of it
                    window.addEventListener('click', (event) => {
                        const changelogModal = document.getElementById('changelogModal');
                        if (event.target === changelogModal) {
                            changelogModal.style.display = 'none';
                            localStorage.setItem('changelog_seen', 'v2.0');
                        }
                    });

                    // Show changelog on first visit or new version
                    if (localStorage.getItem('changelog_seen') !== 'v2.0') {
                        document.getElementById('changelogModal').style.display = 'block';
                    }

                    // Event delegation for dynamically created play and ban buttons
                    document.getElementById('searchResults')?.addEventListener('click', (e) => {
                        // Handle artist row click (search + recently queued artist items)
                        const artistItem = e.target.closest('.artist-result-item');
                        if (artistItem && artistItem.dataset.itemType === 'artist') {
                            const artistId = artistItem.dataset.artistId;
                            const artistName = artistItem.dataset.artistName || '';
                            const artistImage = artistItem.dataset.artistImage || '';
                            if (artistId) {
                                logRecentlyQueuedInteraction('artist', { id: artistId, name: artistName, image: artistImage });
                                openArtistModal(artistId, artistName, artistImage);
                            }
                            return;
                        }

                        // Handle album row click (search + recently queued album items)
                        const albumItem = e.target.closest('.album-result-item');
                        if (albumItem && albumItem.dataset.itemType === 'album') {
                            const albumId = albumItem.dataset.albumId;
                            if (albumId) {
                                const metaText = (albumItem.querySelector('[data-album-meta="true"]')?.textContent || '').trim();
                                const normalizedMeta = normalizeAlbumMeta(metaText || albumItem.dataset.albumArtists || '', albumItem.dataset.albumYear || '');
                                const subtitle = normalizedMeta.display;
                                logRecentlyQueuedInteraction('album', {
                                    id: albumId,
                                    name: albumItem.dataset.albumName || '',
                                    subtitle,
                                    image: albumItem.dataset.albumImage || ''
                                });
                                openAlbumDirect(albumId, albumItem.dataset.albumName, albumItem.dataset.albumImage, normalizedMeta.year || albumItem.dataset.albumYear || '');
                            }
                            return;
                        }

                        // Handle play button
                        if (e.target.matches('.play-button, .play-button-icon') || e.target.closest('.play-button, .play-button-icon')) {
                            const button = e.target.matches('.play-button, .play-button-icon') ? e.target : e.target.closest('.play-button, .play-button-icon');
                            const uri = button.dataset.uri;
                            if (uri) checkPaymentAndPlay(uri, { name: button.dataset.name || '', artist: button.dataset.artist || '', image: button.dataset.image || '' });
                        }

                        // Handle ban button
                        if (e.target.matches('.ban-button-icon') || e.target.closest('.ban-button-icon')) {
                            const button = e.target.matches('.ban-button-icon') ? e.target : e.target.closest('.ban-button-icon');
                            const uri = button.dataset.uri;
                            const name = button.dataset.name;
                            const artist = button.dataset.artist;
                            const image = button.dataset.image || '';

                            // Check if user is banned
                            if (userIsBanned) {
                                Notify('You have been banned from Jukebar. Contact your teacher.', 'error');
                                return;
                            }

                            // Check if user is owner (owners can start votes for free)
                            const userIsOwner = isOwnerClient(currentID);

                            if (userIsOwner) {
                                startBanVote(uri, name, artist, 'student ban', image);
                            } else {
                                pendingAction = 'Ban Vote';
                                pendingTrackUri = uri;
                                pendingTrackName = name;
                                pendingTrackArtist = artist;
                                pendingBanReason = 'student ban';
                                pendingTrackMeta = { image };
                                showPayment();
                            }
                        }
                    });

                    // Expose minimal API via custom events for pay.ejs communication
                    window.addEventListener('paymentSuccess', () => {
                        onPaymentSuccess();
                    });

                    // Expose read-only state for pay.ejs (cannot be directly manipulated from console)
                    window.getPlayerState = function () {
                        return {
                            hasPaid: hasPaid,
                            pendingAction: pendingAction,
                            pendingTrackUri: pendingTrackUri,
                            pendingPlaylistId: pendingPlaylistId,
                            currentID: currentID
                        };
                    };

                    window.setPlayerState = function (updates) {
                        if (updates.hasPaid !== undefined) hasPaid = updates.hasPaid;
                        if (updates.pendingAction !== undefined) pendingAction = updates.pendingAction;
                    };

                    window.purchaseShield = function (trackUri, addedAt) {
                        if (userIsBanned) {
                            Notify('You have been banned from Jukebar. Contact your teacher.', 'error');
                            return;
                        }

                        if (!useJukebar) {
                            Notify('Jukebar is currently disabled by your teacher.', 'error');
                            return;
                        }

                        // Owner gets a quantity picker before adding shields
                        if (isOwnerClient(currentID)) {
                            pendingTrackUri = trackUri;
                            pendingTrackAddedAt = addedAt;
                            pendingShieldQuantity = 1;
                            const input = document.getElementById('owner-shield-quantity-input');
                            if (input) input.value = '';
                            document.getElementById('ownerShieldModal').style.display = 'flex';
                            document.querySelector('.main-content').classList.add('blurred');
                            return;
                        }

                        pendingTrackUri = trackUri;
                        pendingTrackAddedAt = addedAt;
                        pendingAction = 'Skip Shield';
                        showPayment();
                    };

                    async function purchaseShieldAfterPayment(trackUri, addedAt, quantity = 1) {
                        try {
                            const response = await fetch('/purchaseShield', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ trackUri, addedAt, quantity })
                            });
                            const data = await response.json();
                            if (response.ok && data.ok) {
                                Notify(
                                    quantity > 1
                                        ? `${quantity} Skip Shields added!`
                                        : 'Skip Shield added!',
                                    'success'
                                );
                                hasPaid = false;
                                socket.emit('getQueue');
                            } else {
                                Notify(data.error || 'Failed to add Skip Shield', 'error');
                            }
                        } catch (err) {
                            console.error('Error purchasing shield:', err);
                            Notify('Network error purchasing Skip Shield', 'error');
                        }
                    }

                    // WebSocket-based queue synchronization
                    function initializeQueueSync() {
                        socket.on('connect', () => {
                            socket.emit('requestQueueUpdate');
                        });

                        // Handle initial state
                        socket.on('initialState', (data) => {
                            updateQueueDisplay(data.data);
                            updateCurrentlyPlaying(data.data.currentTrack, data.data.isPlaying);
                        });

                        // Handle queue updates (when queue changes)
                        socket.on('queueUpdate', (data) => {
                            updateQueueDisplay(data);
                            // Always update currently playing (function handles null tracks properly)
                            updateCurrentlyPlaying(data.currentTrack, data.isPlaying);
                        });

                        // Handle playback state updates (playing/paused status)
                        socket.on('playbackState', (data) => {
                            updateCurrentlyPlaying(data.currentTrack, data.isPlaying);
                        });

                        // Handle current track updates (from periodic sync)
                        socket.on('currentTrack', (data) => {
                            //console.log('currentTrack event received:', data);
                            updateCurrentlyPlaying(data, true);
                        });

                        // Handle notifications only
                        socket.on('queueAdd', (data) => {
                            showNotification(`"${data.track.name}" added to queue`, 'success');
                        });

                        socket.on('skip', (data) => {
                            showNotification('Track skipped', 'info');
                        });

                        // Handle shield purchase confirmation
                        socket.on('shieldPurchased', (data) => {
                            if (data.ok) {
                                Notify(data.message || 'Skip Shield added!', 'success');
                                socket.emit('getQueue'); // Refresh queue
                            } else {
                                Notify(data.error || 'Failed to add Skip Shield', 'error');
                            }
                        });

                        // Handle ban vote events
                        socket.on('banVoteStarted', (data) => {
                            console.log('banVoteStarted received:', data);
                            showBanVote(data);
                        });

                        socket.on('banVoteUpdate', (data) => {
                            console.log('banVoteUpdate received:', data);
                            updateBanVoteDisplay(data);
                        });

                        socket.on('banVotePassed', (data) => {
                            console.log('banVotePassed received:', data);
                            hideBanVote();
                            Notify(`Vote passed! "${data.trackName}" has been banned.`, 'success');
                        });

                        socket.on('banVoteFailed', (data) => {
                            console.log('banVoteFailed received:', data);
                            hideBanVote();
                            const reason = data.reason ? ` (${data.reason})` : '';
                            Notify(`Vote failed${reason}. "${data.trackName}" was not banned.`, 'error');
                        });

                        socket.on('banVoteError', (data) => {
                            console.log('banVoteError received:', data);
                            Notify(data.error || 'Ban vote error', 'error');
                        });

                        socket.on('recentlyQueuedUpdate', (track) => {
                            const searchInput = document.getElementById('searchInput');
                            const searchResults = document.getElementById('searchResults');
                            if (!searchResults) return;

                            const isSearchActive = searchInput && searchInput.value.trim() !== '';

                            if (!isSearchActive) {
                                // Recently queued is visible — prepend the new track without a full refetch.
                                // Remove any existing entry for this URI so it moves to the top (dedup).
                                searchResults.querySelectorAll(`.search-result-item[data-uri="${track.uri}"]`).forEach(el => el.remove());

                                const header = searchResults.querySelector('.recently-queued-header');
                                const insertBefore = header ? header.nextElementSibling : null;

                                const trackDiv = document.createElement('div');
                                trackDiv.className = 'search-result-item';
                                trackDiv.dataset.uri = track.uri;
                                trackDiv.innerHTML = `
                                    <img src="${track.album?.image || ''}" alt="${track.album?.name || ''}" class="album-cover" />
                                    <div class="search-result-content-outer">
                                        <div class="thebackgroundoftheitemsthatareinthesearchresults"></div>
                                        <div class="search-result-content-pushies">
                                            <div class="search-result-title" title="${track.name}">${track.name}</div>
                                            <div class="search-result-artist" title="${track.artist}">${track.artist}</div>
                                            <div class="search-result-actions">
                                                <button class="play-button-icon" data-uri="${track.uri}" data-name="${(track.name || '').replace(/"/g, '&quot;')}" data-artist="${(track.artist || '').replace(/"/g, '&quot;')}" data-image="${track.album?.image || ''}" title="Add to queue">
                                                    <img src="/img/play.png" alt="Play" class="play-icon">
                                                </button>
                                                <button class="ban-button-icon" data-uri="${track.uri}" data-name="${(track.name || '').replace(/"/g, '&quot;')}" data-artist="${(track.artist || '').replace(/"/g, '&quot;')}" data-image="${track.album?.image || ''}" title="Vote to ban">
                                                    <img src="/img/ban.png" alt="Ban" class="ban-icon">
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                `;

                                if (insertBefore) {
                                    searchResults.insertBefore(trackDiv, insertBefore);
                                } else {
                                    // No header yet — do a full reload to get the header too
                                    loadRecentlyQueued();
                                }
                            }
                            // If search is active we leave it alone; the list will be fresh next time the input is cleared.
                        });

                        socket.on('queueHistoryUpdated', () => {
                            const searchResults = document.getElementById('searchResults');
                            if (searchResults) {
                                searchResults.innerHTML = '';
                            }
                            loadRecentlyQueued();
                        });

                        socket.on('recentlyQueuedCleared', () => {
                            const searchResults = document.getElementById('searchResults');
                            if (searchResults) {
                                searchResults.innerHTML = '';
                            }
                            loadRecentlyQueued();
                        });
                    }

                    // Initialize WebSocket-based queue sync after defining the function
                    initializeQueueSync();
                })();

                // Escape values used inside inline onclick handlers
                function escapeForInlineOnclick(value) {
                    return String(value ?? '')
                        .replace(/&/g, '&amp;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;')
                        .replace(/\\/g, '\\\\')
                        .replace(/'/g, "\\'")
                        .replace(/"/g, '&quot;');
                }

                // Update queue display with WebSocket data
                function updateQueueDisplay(data) {
                    const queueDiv = document.getElementById('queue');
                    if (!queueDiv) return;

                    // Handle different data structures
                    let queue = data.queue || data.data?.queue || [];

                    if (queue && queue.length > 0) {
                        //console.log('Displaying', queue.length, 'tracks');
                        queueDiv.innerHTML = queue.map((track, index) => {
                            // Safely convert addedBy to string, handling [object Object] cases
                            let addedByDisplay = track.addedBy;
                            if (typeof addedByDisplay === 'object' || addedByDisplay === '[object Object]') {
                                addedByDisplay = 'Spotify';
                            }

                            if ((track.isAnon === 1 || track.isAnon === true) && userPermission < 3) {
                                addedByDisplay = 'Anonymous';
                            }

                            const shieldCount = track.skipShields || 0;

                            const safeUri = escapeForInlineOnclick(track.uri);
                            const safeName = escapeForInlineOnclick(track.name);
                            const safeArtist = escapeForInlineOnclick(track.artist);
                            const safeImage = escapeForInlineOnclick(track.image);

                            return `
                        <div class="queue-item">
                            <img src="${track.image}" alt="${track.name}" class="album-cover-small">
                            <div class="queue-item-content">
                                <div class="queue-item-title">${track.name}</div>
                                <div class="queue-item-artist">${track.artist}</div>
                                <div class="queue-item-added-by">Added by ${addedByDisplay || 'Spotify'}</div>
                                ${shieldCount > 0 ? `<span class="shield-badge"><img src="/img/skipShield.png" alt="shield" class="shield-badge-icon"> ${shieldCount}</span>` : ''}
                            </div>
                            <button class="ellipsis-button" onclick="openSongMenu('${safeUri}', '${safeName}', '${safeArtist}', '${safeImage}', ${track.addedAt || 0}, event)" title="More options">
                                <svg width="16" height="4" viewBox="0 0 16 4" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="2" cy="2" r="2" fill="currentColor"/>
                                    <circle cx="8" cy="2" r="2" fill="currentColor"/>
                                    <circle cx="14" cy="2" r="2" fill="currentColor"/>
                                </svg>
                            </button>
                        </div>
                    `;
                        }).join('');
                    } else {
                        //console.log('QUEUE CLEARED - No tracks in queue, showing empty message');
                        queueDiv.innerHTML = '<p class="no-queue">No tracks in queue</p>';
                    }
                }

                // Track the last displayed track to avoid unnecessary re-renders
                let lastDisplayedTrackUri = null;

                function setControlButtonsDisabled(disabled) {
                    ['skip-button', 'now-ban-button', 'now-shield-button'].forEach(id => {
                        const btn = document.getElementById(id);
                        if (btn) btn.disabled = disabled;
                    });
                }

                // Update currently playing with WebSocket data
                function updateCurrentlyPlaying(track, isPlaying) {
                    const currentDiv = document.getElementById('currentlyPlaying');
                    const railDiv = document.getElementById('railNowPlaying');
                    if (!currentDiv) return;

                    if (track) {
                        // Get the current track URI
                        const trackUri = track.uri || track.id;
                        const trackUriForActions = trackUri;
                        const addedAtForActions = track.addedAt || 0;
                        currentTrackActionState = {
                            uri: trackUriForActions,
                            addedAt: addedAtForActions,
                            name: track.name,
                            artist: track.artist,
                            image: track.album?.image || ''
                        };

                        // Update global currentlyPlayingUri for skip functionality
                        if (track.uri) {
                            currentlyPlayingUri = track.uri.replace('spotify:track:', '');
                        } else if (track.id) {
                            currentlyPlayingUri = track.id;
                        }

                        // Update global progress letiables from server data
                        // Only update progress if it's a different track or if we don't have progress yet
                        if (lastDisplayedTrackUri !== trackUri) {
                            // New track - accept server's progress data
                            currentProgress = track.progress || 0;
                            currentDuration = track.duration || 0;
                        } else {
                            // Same track - only update duration if we don't have it
                            if (!currentDuration && track.duration) {
                                currentDuration = track.duration;
                            }
                            // Don't update progress - let the interval handle it
                        }
                        isCurrentlyPlaying = isPlaying;

                        // Enable controls when a track is active
                        setControlButtonsDisabled(false);

                        // Update shield badge on skip button (must be before early return)
                        const currentShieldCount = track.skipShields || 0;
                        const skipBtnShield = document.getElementById('skip-button-showie-shield');
                        if (skipBtnShield) {
                            skipBtnShield.innerText = currentShieldCount;
                            if (currentShieldCount < 1) {
                                skipBtnShield.classList.add('hidiethebutton');
                            } else {
                                skipBtnShield.classList.remove('hidiethebutton');
                            }
                        }

                        // If same track, just update progress bar without re-rendering
                        if (lastDisplayedTrackUri === trackUri) {
                            updateProgressDisplay();
                            return;
                        }

                        // Different track - do full re-render
                        lastDisplayedTrackUri = trackUri;

                        // Handle anonymous mode display
                        let addedByDisplay = track.addedBy || 'Spotify';
                        if (typeof addedByDisplay === 'object' || addedByDisplay === '[object Object]') {
                            addedByDisplay = 'Spotify';
                        }
                        if ((track.isAnon === 1 || track.isAnon === true) && userPermission < 3) {
                            addedByDisplay = 'Anonymous';
                        }

                        const shieldCount = track.skipShields || 0;

                        // Format time as mm:ss
                        const formatTime = (ms) => {
                            const totalSeconds = Math.floor(ms / 1000);
                            const minutes = Math.floor(totalSeconds / 60);
                            const seconds = totalSeconds % 60;
                            return `${minutes}:${seconds.toString().padStart(2, '0')}`;
                        };

                        const currentTime = formatTime(currentProgress);
                        const totalTime = formatTime(currentDuration);

                        const imageUrl = track.image || track.album?.image || '/img/placeholder.png';

                        const safeCurrentUri = escapeForInlineOnclick(track.uri);
                        const safeCurrentName = escapeForInlineOnclick(track.name);
                        const safeCurrentArtist = escapeForInlineOnclick(track.artist);
                        const safeCurrentImage = escapeForInlineOnclick(imageUrl);

                        currentDiv.innerHTML = `
                        <div class="current-item queue-item">
                            <img src="${imageUrl}" alt="${track.name}" class="album-cover-small">
                            <div class="queue-item-content">
                                <div class="queue-item-title">${track.name}</div>
                                <div class="queue-item-artist">${track.artist}</div>
                                <div class="queue-item-added-by">Added by ${addedByDisplay}</div>
                                ${shieldCount > 0 ? `<span class="shield-badge"><img src="/img/skipShield.png" alt="shield" class="shield-badge-icon"> ${shieldCount}</span>` : ''}
                                <div class="progress-container">
                                    <div class="progress-bar">
                                        <div class="progress-fill" id="progress-fill"></div>
                                    </div>
                                    <div class="progress-time" id="track-progress-display">${currentTime} / ${totalTime}</div>
                                </div>
                            </div>
                        </div>
                    `;

                        if (railDiv) {
                            railDiv.innerHTML = `
                            <div class="player-rail-track">
                                <img src="${imageUrl}" alt="${track.name}" class="player-rail-cover">
                                <div class="player-rail-track-meta">
                                    <div class="player-rail-track-title">${track.name}</div>
                                    <div class="player-rail-track-artist">${track.artist}</div>
                                    <div class="player-rail-track-by">Added by ${addedByDisplay}</div>
                                </div>
                            </div>
                            `;
                        }

                        // Update progress bar immediately after render
                        updateProgressDisplay();

                        // Start progress update interval
                        startProgressInterval();
                    } else {
                        currentlyPlayingUri = null;
                        lastDisplayedTrackUri = null;
                        currentProgress = 0;
                        currentDuration = 0;
                        isCurrentlyPlaying = false;
                        currentTrackActionState = null;
                        stopProgressInterval();
                        setControlButtonsDisabled(true);
                        currentDiv.innerHTML = '<p>No track is currently playing. Ask your teacher to start spotify</p>';
                        if (railDiv) railDiv.innerHTML = '<p class="player-rail-empty">No track currently playing.</p>';
                    }
                }

                // Start interval to update progress every second
                function startProgressInterval() {
                    stopProgressInterval(); // Clear any existing interval

                    progressInterval = setInterval(() => {
                        if (isCurrentlyPlaying && currentProgress < currentDuration) {
                            currentProgress += 1000; // Increment by 1 second
                            updateProgressDisplay();
                        }
                    }, 1000);
                }

                // Stop progress interval
                function stopProgressInterval() {
                    if (progressInterval) {
                        clearInterval(progressInterval);
                        progressInterval = null;
                    }
                }

                // Update just the progress display without re-rendering everything
                function updateProgressDisplay() {
                    const progressDisplay = document.getElementById('track-progress-display');
                    const progressFill = document.getElementById('progress-fill');

                    if (progressDisplay) {
                        const formatTime = (ms) => {
                            const totalSeconds = Math.floor(ms / 1000);
                            const minutes = Math.floor(totalSeconds / 60);
                            const seconds = totalSeconds % 60;
                            return `${minutes}:${seconds.toString().padStart(2, '0')}`;
                        };

                        progressDisplay.textContent = `${formatTime(currentProgress)} / ${formatTime(currentDuration)}`;
                    }

                    if (progressFill && currentDuration > 0) {
                        const percentage = (currentProgress / currentDuration) * 100;
                        progressFill.style.width = `${percentage}%`;
                    }
                }

                function showNotification(message, type = 'info') {
                    // Simple notification system
                    const notification = document.createElement('div');
                    notification.className = `notification notification-${type}`;
                    notification.textContent = message;
                    notification.style.cssText = `
                    position: fixed;
                    top: 20px;
                    right: 20px;
                    padding: 10px 20px;
                    background: ${type === 'success' ? '#4CAF50' : type === 'error' ? '#f44336' : '#2196F3'};
                    color: white;
                    border-radius: 4px;
                    z-index: 1000;
                    animation: slideIn 0.3s ease-out;
                `;

                    document.body.appendChild(notification);

                    setTimeout(() => {
                        notification.remove();
                    }, 3000);
                }

                function openSongMenu(uri, name, artist, imageUrl, addedAt, event) {
                    // Prevent event bubbling
                    if (event) {
                        event.stopPropagation();
                    }

                    // Get button position
                    const button = event?.target.closest('.ellipsis-button');
                    const rect = button?.getBoundingClientRect();

                    // Calculate dropdown position (below and to the left of button)
                    const x = rect ? rect.left - 150 : 100; // Offset left to align with button
                    const y = rect ? rect.bottom + 5 : 100; // Below button with small gap

                    // Dispatch event to show dropdown at position
                    window.dispatchEvent(new CustomEvent('updateSongMenu', {
                        detail: { uri, name, artist, imageUrl, addedAt, x, y }
                    }));
                }

                let voteTimerInterval = null;

                function showBanVote(data) {
                    const modal = document.getElementById('banVoteModal');
                    const title = document.getElementById('banVoteTitle');
                    const status = document.getElementById('banVoteStatus');
                    const banReason = data.reason ? ` Reason: ${data.reason}` : '';

                    // gives the name of the user that started the ban
                    title.textContent = `${data.initiator} has started a vote to ban "${data.trackName}" by ${data.trackArtist}`;

                    const onlineCount = data.onlineCount || data.totalOnline || 0;
                    status.textContent = `Ban vote: "${data.trackName}" - Yes: ${data.yesVotes || 1}, No: ${data.noVotes || 0} (${onlineCount} online).${banReason}`;

                    document.getElementById('banVoteYes').textContent = data.yesVotes || 1;
                    document.getElementById('banVoteNo').textContent = data.noVotes || 0;
                    document.getElementById('banVoteOnline').textContent = onlineCount;

                    modal.dataset.voteId = data.voteId;
                    modal.dataset.trackName = data.trackName;
                    modal.dataset.initiatorId = data.initiatorId;
                    modal.classList.remove('minimized'); // Start expanded
                    modal.style.display = 'block';

                    // If current user is the initiator, disable voting buttons (they already voted yes)
                    const currentUserId = <%= JSON.stringify(userID || null) %>;
                    const voteButtons = modal.querySelectorAll('.vote-yes-btn, .vote-no-btn');
                    if (currentUserId && data.initiatorId && String(currentUserId) === String(data.initiatorId)) {
                        voteButtons.forEach(btn => {
                            btn.disabled = true;
                            btn.style.opacity = '0.5';
                            btn.style.cursor = 'not-allowed';
                        });
                    } else {
                        // Enable buttons for other users
                        voteButtons.forEach(btn => {
                            btn.disabled = false;
                            btn.style.opacity = '1';
                            btn.style.cursor = 'pointer';
                        });
                    }

                    // Start countdown timer for everyone
                    startVoteTimer(data.expiresIn || 60000);
                }

                function updateBanVoteDisplay(data) {
                    const modal = document.getElementById('banVoteModal');
                    if (!modal || modal.style.display === 'none') return;

                    const status = document.getElementById('banVoteStatus');
                    const onlineCount = data.onlineCount || data.totalOnline || document.getElementById('banVoteOnline').textContent || 0;
                    status.textContent = `Ban vote: "${data.trackName}" - Yes: ${data.yesVotes}, No: ${data.noVotes} (${onlineCount} online)`;

                    document.getElementById('banVoteYes').textContent = data.yesVotes;
                    document.getElementById('banVoteNo').textContent = data.noVotes;
                    if (data.onlineCount || data.totalOnline) {
                        document.getElementById('banVoteOnline').textContent = onlineCount;
                    }
                }

                function castVote(vote) {
                    const modal = document.getElementById('banVoteModal');
                    const voteId = modal.dataset.voteId;

                    if (!voteId || !window.banVoteSocket) {
                        if (typeof Notify === 'function') {
                            Notify('Unable to cast vote', 'error');
                        } else {
                            Notify('Unable to cast vote');
                        }
                        return;
                    }

                    window.banVoteSocket.emit('castBanVote', { voteId, vote });

                    // Disable vote buttons after voting
                    const voteButtons = modal.querySelectorAll('.vote-yes-btn, .vote-no-btn');
                    voteButtons.forEach(btn => {
                        btn.disabled = true;
                        btn.style.opacity = '0.5';
                        btn.style.cursor = 'not-allowed';
                    });

                    if (typeof Notify === 'function') {
                        Notify(`You voted ${vote}`, 'info');
                    }
                }

                function startVoteTimer(durationMs) {
                    // Clear any existing timer
                    if (voteTimerInterval) {
                        clearInterval(voteTimerInterval);
                    }

                    const timerElement = document.getElementById('vote-timer');
                    if (!timerElement) return;

                    let remainingMs = durationMs;
                    const startTime = Date.now();

                    voteTimerInterval = setInterval(() => {
                        remainingMs = durationMs - (Date.now() - startTime);

                        if (remainingMs <= 0) {
                            clearInterval(voteTimerInterval);
                            timerElement.textContent = '0s remaining';
                            // Hide modal after timer ends
                            setTimeout(() => {
                                const modal = document.getElementById('banVoteModal');
                                const trackName = modal.dataset.trackName || 'this track';
                                hideBanVote();
                                Notify(`Vote expired for "${trackName}"`, 'info');
                            }, 1000);
                            return;
                        }

                        const seconds = Math.ceil(remainingMs / 1000);
                        timerElement.textContent = `${seconds}s remaining`;
                    }, 100);
                }

                function hideBanVote() {
                    const modal = document.getElementById('banVoteModal');
                    if (modal) {
                        modal.style.display = 'none';
                        modal.classList.add('minimized');
                    }

                    // Clear timer
                    if (voteTimerInterval) {
                        clearInterval(voteTimerInterval);
                        voteTimerInterval = null;
                    }
                }

                function toggleBanVoteMinimize() {
                    const modal = document.getElementById('banVoteModal');
                    if (modal) {
                        modal.classList.toggle('minimized');
                        const btn = document.getElementById('banVoteMinimize');
                        if (btn) {
                            btn.textContent = modal.classList.contains('minimized') ? '+' : '−';
                        }
                    }
                }

                // Add event listeners for ban vote modal buttons
                document.getElementById('banVoteMinimize')?.addEventListener('click', toggleBanVoteMinimize);

                // ============================================================
                // CUSTOM PLAYLISTS
                // ============================================================

                function switchSidebarTab(tab) {
                    closeCustomPlaylistContextMenu();
                    document.getElementById('tab-playlists-panel').style.display = tab === 'playlists' ? '' : 'none';
                    document.getElementById('tab-my-playlists-panel').style.display = tab === 'my-playlists' ? '' : 'none';
                    document.getElementById('tab-playlists').classList.toggle('active', tab === 'playlists');
                    document.getElementById('tab-my-playlists').classList.toggle('active', tab === 'my-playlists');
                    if (tab === 'my-playlists') loadMyPlaylists();
                }
                window.switchSidebarTab = switchSidebarTab;

                async function loadMyPlaylists() {
                    const listEl = document.getElementById('myPlaylistsList');
                    listEl.innerHTML = '<p style="text-align:center;color:#b3b3b3;">Loading...</p>';
                    try {
                        const res = await fetch('/api/custom-playlists');
                        const data = await res.json();
                        if (!data.ok) throw new Error(data.error);
                        if (!data.playlists.length) {
                            listEl.innerHTML = '<p style="text-align:center;color:#b3b3b3;">No playlists yet.</p>';
                            return;
                        }
                        listEl.innerHTML = '';
                        data.playlists.forEach(pl => {
                            const canEdit = true;
                            const isCreator = !!pl.is_owner;
                            const row = document.createElement('button');
                            row.type = 'button';
                            row.className = 'player-sidebar-item';
                            row.title = pl.name || 'Playlist';

                            const img = document.createElement('img');
                            img.className = 'player-sidebar-cover';
                            img.src = pl.image_url || '/img/placeholder.png';
                            img.alt = pl.name || 'Playlist';

                            const meta = document.createElement('div');
                            meta.className = 'player-sidebar-meta';

                            const name = document.createElement('div');
                            name.className = 'player-sidebar-name';
                            name.textContent = pl.name || 'Untitled Playlist';

                            const sub = document.createElement('div');
                            sub.className = 'player-sidebar-sub';
                            const songsText = `${pl.song_count} song${pl.song_count !== 1 ? 's' : ''}`;
                            sub.textContent = pl.owner_name
                                ? `${songsText} · by ${pl.owner_name}${isCreator ? ' (you)' : ''}`
                                : songsText;

                            meta.appendChild(name);
                            meta.appendChild(sub);
                            row.appendChild(img);
                            row.appendChild(meta);

                            row.addEventListener('click', () => {
                                closeCustomPlaylistContextMenu();
                                openCustomPlaylistTracks(pl.id, pl.name, canEdit);
                            });

                            row.addEventListener('contextmenu', (event) => {
                                event.preventDefault();
                                openCustomPlaylistContextMenu(pl, event);
                            });

                            listEl.appendChild(row);
                        });
                    } catch (err) {
                        listEl.innerHTML = '<p style="text-align:center;color:#ff5555;">Failed to load playlists.</p>';
                    }
                }

                function openCustomPlaylistContextMenu(playlist, event) {
                    const menu = document.getElementById('customPlaylistContextMenu');
                    if (!menu) return;

                    customPlaylistContextTarget = {
                        id: Number(playlist.id),
                        name: String(playlist.name || 'Playlist'),
                        canEdit: true
                    };

                    menu.style.display = 'block';

                    const margin = 8;
                    const rect = menu.getBoundingClientRect();
                    let left = event.clientX;
                    let top = event.clientY;

                    if (left + rect.width + margin > window.innerWidth) {
                        left = window.innerWidth - rect.width - margin;
                    }
                    if (top + rect.height + margin > window.innerHeight) {
                        top = window.innerHeight - rect.height - margin;
                    }

                    menu.style.left = `${Math.max(margin, left)}px`;
                    menu.style.top = `${Math.max(margin, top)}px`;
                }

                function closeCustomPlaylistContextMenu() {
                    const menu = document.getElementById('customPlaylistContextMenu');
                    if (menu) menu.style.display = 'none';
                    customPlaylistContextTarget = null;
                }

                function formatCustomPlaylistTitle(playlistName) {
                    const safeName = String(playlistName || 'Playlist').trim();
                    return `Custom Playlist: ${safeName}`;
                }

                async function playCustomPlaylist(playlistId) {
                    try {
                        const res = await fetch('/api/custom-playlists/queue', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ playlistId })
                        });
                        const data = await res.json();
                        if (!data.ok) {
                            Notify(data.error || 'Failed to play playlist.', 'error');
                            if (res.status === 410) {
                                loadMyPlaylists();
                            }
                            return;
                        }
                        Notify(data.message || 'Playlist started!', 'success');
                        socket.emit('getQueue');
                    } catch {
                        Notify('Network error playing playlist.', 'error');
                    }
                }

                function initiateCustomPlaylistPlay(playlistId) {
                    const parsedPlaylistId = Number(playlistId);
                    if (!parsedPlaylistId) {
                        Notify('Invalid playlist.', 'error');
                        return;
                    }

                    if (userIsBanned) {
                        Notify('You are banned from using Jukebar.', 'error');
                        return;
                    }

                    if (isOwnerClient(currentID)) {
                        playCustomPlaylist(parsedPlaylistId);
                        return;
                    }

                    pendingCustomPlaylistId = parsedPlaylistId;
                    pendingPlaylistId = parsedPlaylistId;
                    pendingAction = 'customPlaylistPlay';
                    showPayment();
                }

                window.playCurrentCustomPlaylist = function () {
                    const playlistId = Number(currentCustomPlaylistId);
                    if (!playlistId) {
                        Notify('No playlist selected.', 'error');
                        return;
                    }
                    closeCustomPlaylistTracksModal();
                    initiateCustomPlaylistPlay(playlistId);
                };

                function openAddSongToCustomPlaylistFromMenu(playlistId, playlistName) {
                    currentCustomPlaylistId = Number(playlistId);
                    currentCustomPlaylistName = playlistName || 'Playlist';
                    currentCustomPlaylistCanEdit = true;
                    document.getElementById('customPlaylistTracksTitle').textContent = formatCustomPlaylistTitle(currentCustomPlaylistName);
                    openAddSongToCustomPlaylist();
                }

                document.getElementById('customPlaylistMenuPlay')?.addEventListener('click', async () => {
                    if (!customPlaylistContextTarget) return;
                    const target = { ...customPlaylistContextTarget };
                    closeCustomPlaylistContextMenu();
                    initiateCustomPlaylistPlay(target.id);
                });

                document.getElementById('customPlaylistMenuAdd')?.addEventListener('click', () => {
                    if (!customPlaylistContextTarget) return;
                    const target = { ...customPlaylistContextTarget };
                    closeCustomPlaylistContextMenu();
                    openAddSongToCustomPlaylistFromMenu(target.id, target.name);
                });

                document.addEventListener('click', (event) => {
                    const menu = document.getElementById('customPlaylistContextMenu');
                    if (!menu || menu.style.display === 'none') return;
                    if (!menu.contains(event.target)) closeCustomPlaylistContextMenu();
                });

                window.addEventListener('resize', closeCustomPlaylistContextMenu);
                window.addEventListener('scroll', closeCustomPlaylistContextMenu, true);

                function escapeHtml(str) {
                    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
                }

                // --- Create Playlist ---
                window.openCreatePlaylistModal = function () {
                    createPlaylistSelectedUris = [];
                    document.getElementById('newPlaylistName').value = '';
                    document.getElementById('createPlaylistSearchInput').value = '';
                    document.getElementById('createPlaylistSearchResults').innerHTML = '';
                    renderCreatePlaylistSelectedSongs();
                    document.getElementById('createPlaylistModal').style.display = 'flex';
                    document.querySelector('.main-content').classList.add('blurred');
                    document.querySelector('.player-bottom-bar')?.classList.add('blurred');
                };

                window.closeCreatePlaylistModal = function () {
                    document.getElementById('createPlaylistModal').style.display = 'none';
                    document.querySelector('.main-content').classList.remove('blurred');
                    document.querySelector('.player-bottom-bar')?.classList.remove('blurred');
                };

                document.getElementById('createPlaylistSearchForm')?.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const now = Date.now();
                    if (createPlaylistSearchInFlight || (now - createPlaylistSearchLastAt) < SEARCH_SUBMIT_COOLDOWN_MS) return;
                    const q = document.getElementById('createPlaylistSearchInput').value.trim();
                    if (!q) return;
                    createPlaylistSearchInFlight = true;
                    createPlaylistSearchLastAt = now;
                    const resultsEl = document.getElementById('createPlaylistSearchResults');
                    resultsEl.innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">Searching...</p>';
                    try {
                        const res = await fetch('/search', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ query: q })
                        });
                        const data = await res.json();
                        const items = data.tracks?.items || [];
                        if (!data.ok || !items.length) {
                            resultsEl.innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">No results.</p>';
                            return;
                        }
                        resultsEl.innerHTML = '';
                        items.slice(0, 10).forEach(track => {
                            const alreadyAdded = createPlaylistSelectedUris.find(t => t.uri === track.uri);
                            const div = document.createElement('div');
                            div.className = 'playlist-search-result';
                            div.innerHTML = `
                                <img src="${track.album?.image || ''}" alt="" class="album-cover" style="width:40px;height:40px;border-radius:6px;flex-shrink:0;" />
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:600;font-size:0.9em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escapeHtml(track.name)}</div>
                                    <div style="color:#b3b3b3;font-size:0.78em;">${escapeHtml(track.artist)}</div>
                                </div>
                                <button class="primary small-btn create-playlist-add-btn ${alreadyAdded ? 'is-added' : ''}" data-uri="${track.uri}" ${alreadyAdded || createPlaylistSelectedUris.length >= 5 ? 'disabled' : ''} onclick="addToCreatePlaylistSelection('${track.uri}', '${escapeHtml(track.name).replace(/'/g, "\\'")}', '${escapeHtml(track.artist).replace(/'/g, "\\'")}', '${track.album?.image || ''}', this)">${alreadyAdded ? 'Added' : 'Add'}</button>`;
                            resultsEl.appendChild(div);
                        });
                        syncCreatePlaylistSearchButtons();
                    } catch {
                        resultsEl.innerHTML = '<p style="color:#ff5555;text-align:center;padding:8px;">Search failed.</p>';
                    } finally {
                        createPlaylistSearchInFlight = false;
                    }
                });

                function syncCreatePlaylistSearchButtons() {
                    const buttons = document.querySelectorAll('#createPlaylistSearchResults .create-playlist-add-btn');
                    const reachedLimit = createPlaylistSelectedUris.length >= 5;
                    buttons.forEach((btn) => {
                        const uri = btn.dataset.uri;
                        const alreadyAdded = !!uri && createPlaylistSelectedUris.some(t => t.uri === uri);
                        if (alreadyAdded) {
                            btn.disabled = true;
                            btn.textContent = 'Added';
                            btn.classList.add('is-added');
                            return;
                        }
                        btn.classList.remove('is-added');
                        btn.textContent = 'Add';
                        btn.disabled = reachedLimit;
                    });
                }

                window.addToCreatePlaylistSelection = function (uri, name, artist, image, buttonEl) {
                    if (createPlaylistSelectedUris.length >= 5 || createPlaylistSelectedUris.find(t => t.uri === uri)) return;
                    createPlaylistSelectedUris.push({ uri, name, artist, image });
                    renderCreatePlaylistSelectedSongs();
                    syncCreatePlaylistSearchButtons();
                };

                function renderCreatePlaylistSelectedSongs() {
                    const el = document.getElementById('createPlaylistSelectedSongs');
                    if (!createPlaylistSelectedUris.length) {
                        el.innerHTML = '';
                        syncCreatePlaylistSearchButtons();
                        return;
                    }
                    el.innerHTML = `<p style="color:#b3b3b3;font-size:0.8em;margin:0 0 4px;">Selected (${createPlaylistSelectedUris.length}/5 free):</p>
                        <div class="playlist-selected-songs-scroll">` +
                        createPlaylistSelectedUris.map((t, i) => `
                            <div class="playlist-selected-item">
                                <img src="${t.image || ''}" alt="" />
                                <div class="playlist-selected-meta">
                                    <div class="playlist-selected-title">${escapeHtml(t.name)}</div>
                                    <div class="playlist-selected-artist">${escapeHtml(t.artist)}</div>
                                </div>
                                <button class="ban-button" style="padding:2px 8px;font-size:0.75em;flex-shrink:0;" onclick="removeFromCreatePlaylistSelection(${i})">✕</button>
                            </div>`).join('') + `</div>`;
                    syncCreatePlaylistSearchButtons();
                }

                window.removeFromCreatePlaylistSelection = function (index) {
                    createPlaylistSelectedUris.splice(index, 1);
                    renderCreatePlaylistSelectedSongs();
                };

                window.submitCreatePlaylist = function () {
                    const name = document.getElementById('newPlaylistName').value.trim();
                    if (!name) { Notify('Please enter a playlist name.', 'error'); return; }
                    pendingCustomPlaylistName = name;
                    closeCreatePlaylistModal();
                    if (isOwnerClient(currentID)) {
                        pendingAction = null;
                        finalizeCreatePlaylist();
                        return;
                    }
                    pendingAction = 'createPlaylist';
                    showPayment();
                };

                async function finalizeCreatePlaylist() {
                    try {
                        const uris = createPlaylistSelectedUris.map(t => t.uri);
                        const res = await fetch('/api/custom-playlists/create', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ name: pendingCustomPlaylistName, trackUris: uris })
                        });
                        const data = await res.json();
                        if (!data.ok) { Notify(data.error || 'Failed to create playlist.', 'error'); return; }
                        Notify(`Playlist "${data.playlist.name}" created!`, 'success');
                        createPlaylistSelectedUris = [];
                        pendingCustomPlaylistName = null;
                        loadMyPlaylists();
                    } catch {
                        Notify('Network error creating playlist.', 'error');
                    }
                }

                // --- View Custom Playlist Tracks ---
                window.openCustomPlaylistTracks = async function (playlistId, playlistName, canEdit = true) {
                    currentCustomPlaylistId = playlistId;
                    currentCustomPlaylistName = playlistName || 'Playlist';
                    currentCustomPlaylistCanEdit = !!canEdit;
                    document.getElementById('customPlaylistTracksTitle').textContent = formatCustomPlaylistTitle(currentCustomPlaylistName);
                    const addTitleEl = document.getElementById('addSongToPlaylistTitle');
                    if (addTitleEl) addTitleEl.textContent = formatCustomPlaylistTitle(currentCustomPlaylistName);
                    const addSongBtn = document.getElementById('customPlaylistAddSongBtn');
                    if (addSongBtn) addSongBtn.style.display = currentCustomPlaylistCanEdit ? '' : 'none';
                    document.getElementById('customPlaylistTracksList').innerHTML = '<p style="color:#b3b3b3;text-align:center;">Loading...</p>';
                    document.getElementById('customPlaylistTracksModal').style.display = 'flex';
                    window.refreshModalBlurState();
                    try {
                        const res = await fetch(`/api/custom-playlists/${playlistId}/tracks`);
                        const data = await res.json();
                        if (data?.playlist && typeof data.playlist.canEdit === 'boolean') {
                            currentCustomPlaylistCanEdit = data.playlist.canEdit;
                            if (addSongBtn) addSongBtn.style.display = currentCustomPlaylistCanEdit ? '' : 'none';
                        }
                        renderCustomPlaylistTracks(data);
                    } catch {
                        document.getElementById('customPlaylistTracksList').innerHTML = '<p style="color:#ff5555;">Failed to load tracks.</p>';
                    }
                };

                function renderCustomPlaylistTracks(data) {
                    const el = document.getElementById('customPlaylistTracksList');
                    if (!data.ok) { el.innerHTML = `<p style="color:#ff5555;">${escapeHtml(data.error || 'Error')}</p>`; return; }
                    if (!data.tracks.length) { el.innerHTML = '<p style="color:#b3b3b3;text-align:center;">No tracks yet.</p>'; return; }
                    el.innerHTML = '';
                    data.tracks.forEach(track => {
                        const div = document.createElement('div');
                        div.className = 'queue-item';
                        div.innerHTML = `
                            <img src="${track.album.image || ''}" alt="" class="album-cover" style="width:40px;height:40px;" />
                            <div class="queue-item-content" style="flex:1;">
                                <div class="queue-item-title">${escapeHtml(track.name)}</div>
                                <div class="queue-item-artist">${escapeHtml(track.artist)}</div>
                            </div>
                            <button class="ban-button" style="font-size:0.75em;padding:4px 8px;white-space:nowrap;" onclick="initiateRemoveSong('${track.uri}')">Remove</button>`;
                        el.appendChild(div);
                    });
                }

                window.closeCustomPlaylistTracksModal = function () {
                    document.getElementById('customPlaylistTracksModal').style.display = 'none';
                    window.refreshModalBlurState();
                    currentCustomPlaylistId = null;
                    currentCustomPlaylistName = null;
                    currentCustomPlaylistCanEdit = false;
                };

                window.initiateRemoveSong = function (trackUri) {
                    pendingCustomPlaylistTrackUri = trackUri;
                    pendingCustomPlaylistId = currentCustomPlaylistId;
                    pendingPlaylistId = currentCustomPlaylistId;
                    if (isOwnerClient(currentID)) {
                        pendingAction = null;
                        finalizeRemoveSongFromPlaylist(trackUri);
                        return;
                    }
                    pendingAction = 'removePlaylistSong';
                    showPayment();
                };

                async function finalizeRemoveSongFromPlaylist(trackUri) {
                    try {
                        const res = await fetch('/api/custom-playlists/remove-song', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ playlistId: pendingCustomPlaylistId, trackUri })
                        });
                        const data = await res.json();
                        if (!data.ok) { Notify(data.error || 'Failed to remove song.', 'error'); return; }
                        Notify('Song removed from playlist.', 'success');
                        pendingCustomPlaylistTrackUri = null;
                        if (currentCustomPlaylistId) {
                            openCustomPlaylistTracks(currentCustomPlaylistId, currentCustomPlaylistName || 'Playlist', currentCustomPlaylistCanEdit);
                        }
                        pendingCustomPlaylistId = null;
                        loadMyPlaylists();
                    } catch {
                        Notify('Network error removing song.', 'error');
                    }
                }

                // --- Add Song to Custom Playlist ---
                window.openAddSongToCustomPlaylist = function () {
                    const addTitleEl = document.getElementById('addSongToPlaylistTitle');
                    if (addTitleEl) addTitleEl.textContent = formatCustomPlaylistTitle(currentCustomPlaylistName || 'Playlist');
                    document.getElementById('addSongSearchInput').value = '';
                    document.getElementById('addSongSearchResults').innerHTML = '';
                    document.getElementById('addSongToPlaylistModal').style.display = 'flex';
                    window.refreshModalBlurState();
                };

                window.closeAddSongToPlaylistModal = function () {
                    document.getElementById('addSongToPlaylistModal').style.display = 'none';
                    window.refreshModalBlurState();
                };

                document.getElementById('addSongSearchForm')?.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const now = Date.now();
                    if (addSongSearchInFlight || (now - addSongSearchLastAt) < SEARCH_SUBMIT_COOLDOWN_MS) return;
                    const q = document.getElementById('addSongSearchInput').value.trim();
                    if (!q) return;
                    addSongSearchInFlight = true;
                    addSongSearchLastAt = now;
                    const resultsEl = document.getElementById('addSongSearchResults');
                    resultsEl.innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">Searching...</p>';
                    try {
                        const res = await fetch('/search', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ query: q })
                        });
                        const data = await res.json();
                        const items = data.tracks?.items || [];
                        if (!data.ok || !items.length) {
                            resultsEl.innerHTML = '<p style="color:#b3b3b3;text-align:center;padding:8px;">No results.</p>';
                            return;
                        }
                        resultsEl.innerHTML = '';
                        items.slice(0, 10).forEach(track => {
                            const div = document.createElement('div');
                            div.className = 'playlist-search-result';
                            div.innerHTML = `
                                <img src="${track.album?.image || ''}" alt="" class="album-cover" style="width:40px;height:40px;border-radius:6px;flex-shrink:0;" />
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:600;font-size:0.9em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escapeHtml(track.name)}</div>
                                    <div style="color:#b3b3b3;font-size:0.78em;">${escapeHtml(track.artist)}</div>
                                </div>
                                <button class="primary small-btn" onclick="initiateAddSongToPlaylist('${track.uri}')">Add</button>`;
                            resultsEl.appendChild(div);
                        });
                    } catch {
                        resultsEl.innerHTML = '<p style="color:#ff5555;text-align:center;padding:8px;">Search failed.</p>';
                    } finally {
                        addSongSearchInFlight = false;
                    }
                });

                window.initiateAddSongToPlaylist = function (trackUri) {
                    pendingCustomPlaylistTrackUri = trackUri;
                    pendingCustomPlaylistId = currentCustomPlaylistId;
                    pendingPlaylistId = currentCustomPlaylistId;
                    closeAddSongToPlaylistModal();
                    if (isOwnerClient(currentID)) {
                        pendingAction = null;
                        finalizeAddSongToPlaylist(trackUri);
                        return;
                    }
                    pendingAction = 'addPlaylistSong';
                    showPayment();
                };

                async function finalizeAddSongToPlaylist(trackUri) {
                    try {
                        const res = await fetch('/api/custom-playlists/add-song', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ playlistId: pendingCustomPlaylistId, trackUri })
                        });
                        const data = await res.json();
                        if (!data.ok) { Notify(data.error || 'Failed to add song.', 'error'); return; }
                        Notify('Song added to playlist!', 'success');
                        if (currentCustomPlaylistId) {
                            openCustomPlaylistTracks(currentCustomPlaylistId, currentCustomPlaylistName || 'Playlist', currentCustomPlaylistCanEdit);
                        }
                        pendingCustomPlaylistId = null;
                        loadMyPlaylists();
                    } catch {
                        Notify('Network error adding song.', 'error');
                    }
                }

                const chance2 = Math.floor(Math.random() * 100);
                if (chance2 === 69) document.querySelector('.changelog-header h1').innerText = "Jubekar Changelog";


            </script>
</body>

</html>