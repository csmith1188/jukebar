<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jukebar - Player</title>
    <link rel="icon" href="/img/favicon.png">
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>

</head>

<body class="player-page">
    <div id="notification" class="notification">
        <span class="close-btn" id="close-notification">&times;</span>
        <p id="notification-text"></p>
    </div>
    <%- include('partials/header', { page: 'player' }) %>
        <div class="main-content player-main-content">
            <div class="player-topbar">
                <p class="user-greeting">Logged in as: <strong>
                        <%= user %>
                    </strong> <span class="user-count">(<span id="onlineUserCount">1</span> online)</span></p>
            </div>

            <div class="player-shell">
                <aside class="player-sidebar" aria-label="Playlists">
                    <div class="player-sidebar-header">
                        <div class="player-sidebar-tabs">
                            <button class="sidebar-tab active" id="tab-playlists" onclick="switchSidebarTab('playlists')">Teacher Playlists</button>
                            <button class="sidebar-tab" id="tab-my-playlists" onclick="switchSidebarTab('my-playlists')">Class Playlists</button>
                        </div>
                    </div>
                    <div id="tab-playlists-panel">
                        <div id="studentPlaylistsList" class="player-sidebar-list">
                            <p style="text-align:center;color:#b3b3b3;">Loading...</p>
                        </div>
                    </div>
                    <div id="tab-my-playlists-panel" style="display:none;">
                        <div class="player-sidebar-list-actions">
                            <button class="primary small-btn" id="createPlaylistBtn" onclick="openCreatePlaylistModal()">+ New Playlist (<%= createPlaylistAmount %> digipogs)</button>
                        </div>
                        <div id="myPlaylistsList" class="player-sidebar-list">
                            <p style="text-align:center;color:#b3b3b3;">Loading...</p>
                        </div>
                    </div>
                </aside>

                <main class="player-main" aria-label="Search">
                    <div id="spotifyPlayer" class="player-search-panel">
                        <form id="searchForm">
                            <div class="search-container">
                                <input type="text" id="searchInput" placeholder="Search for a song, artist, or album"
                                    required>
                                <button type="submit" id="searchButton">
                                    <img src="/img/search.png" alt="Search" class="search-icon">
                                </button>
                            </div>
                        </form>
                        <% if (ownerIDs.includes(userID)) { %>
                            <div class="owner-anon-container">
                                <label class="owner-anon-label">
                                    <input type="checkbox" id="owner-anon-mode">
                                    Add songs anonymously
                                </label>
                            </div>
                            <% } %>
                                <div id="searchResults"></div>
                    </div>
                </main>

                <aside class="player-right-rail" aria-label="Now playing details">
                    <div class="player-rail-title">Queue</div>
                    <div id="queue" class="player-rail-queue"></div>
                </aside>
            </div>
        </div>

        <footer class="player-bottom-bar" aria-label="Now playing">
            <div id="songStats" class="player-nowplaying">
                <div class="player-nowplaying-left">
                    <div id="currentlyPlaying"></div>
                </div>
                <div class="player-nowplaying-center">
                    <div class="player-controls" aria-label="Playback controls">
                        <button id="now-ban-button" class="player-control-btn player-control-btn--action" type="button"
                            aria-label="Vote Ban" title="Vote Ban" disabled>
                            <img src="/img/ban.png" alt="Ban" class="player-control-icon">
                        </button>
                        <button id="skip-button" class="player-control-btn player-control-btn--primary" type="button"
                            aria-label="Skip" disabled>
                            <div id="skip-button-showie-shield">
                                1
                            </div>
                            <img src="/img/skip.png" alt="Skip" class="player-control-icon player-control-icon--skip">
                        </button>
                        <button id="now-shield-button" class="player-control-btn player-control-btn--action"
                            type="button" aria-label="Skip Shield" title="Skip Shield" disabled>
                            <img src="/img/skipShield.png" alt="Skip Shield" class="player-control-icon">
                        </button>
                    </div>
                </div>
                <div class="player-nowplaying-right">
                </div>
            </div>
        </footer>
        <div id="paymentModal" class="payment-modal">
            <div class="payment-content">
                <button id="hide-payment">&times;</button>

                <%- include('partials/pay') %>
            </div>
        </div>

        <div id="playlistPaymentModal" class="payment-modal" style="display:none;">
            <div class="payment-content playlist-pay-content">
                <h3 class="ban-reason-title">Play Playlist</h3>
                <div class="playlist-pay-summary">
                    <div id="playlistPayTitle" class="playlist-pay-title">Playlist</div>
                    <div id="playlistPayMeta" class="playlist-pay-meta">0 queueable tracks</div>
                    <div id="playlistPayCost" class="playlist-pay-cost">0 Digipogs</div>
                </div>
                <p style="color:#ffaa00; font-size:0.85em; text-align:center; margin:8px 0;">Note: Playing a playlist will clear the current queue.</p>
                <input id="playlist-pay-pin" type="password" pattern="\d*" inputmode="numeric" maxlength="6"
                    placeholder="Enter PIN" oninput="this.value = this.value.replace(/[^0-9]/g,'');" />
                <label class="medium label-inline playlist-pay-save" for="playlistSavePIN">
                    Save PIN for next purchase
                    <input id="playlistSavePIN" type="checkbox" />
                </label>
                <div class="ban-reason-actions" style="display:flex; gap:8px; justify-content:flex-start;">
                    <button id="playlist-pay-confirm" class="unban-button" type="button">Pay & Queue</button>
                    <button id="playlist-pay-cancel" class="ban-button" type="button">Cancel</button>
                </div>
            </div>
        </div>

        <div id="ownerShieldModal" class="owner-shield-modal">
            <div class="owner-shield-content">
                <button id="owner-shield-close" class="owner-shield-close">&times;</button>
                <h3 class="owner-shield-title"><img src="/img/skipShield.png" alt="Shield" class="notify-shield-icon">
                    Add Skip Shields</h3>
                <div class="shield-quantity-section" style="display:block;">
                    <label class="shield-quantity-label">How many shields?</label>
                    <input type="number" id="owner-shield-quantity-input" class="shield-quantity-input" min="1"
                        max="1000" placeholder="1"
                        onkeydown="if(['+','-','.','e','E'].includes(event.key)) event.preventDefault();" oninput="
                            this.value = this.value.replace(/[^0-9]/g, '');
                            let v = parseInt(this.value) || 1;
                            if (v > 1000) {
                                Notify('You\'ve reached the maximum of 1000 shields', 'error');
                                v = 1000;
                                this.value = v;
                            }
                            if (v < 1) this.value = 1;
                            pendingShieldQuantity = v;
                        ">
                </div>
                <button id="owner-shield-confirm" class="owner-shield-confirm-btn">Add Shields</button>
            </div>
        </div>

        <!-- Create Custom Playlist Modal -->
        <div id="createPlaylistModal" class="payment-modal" style="display:none;">
            <div class="payment-content">
                <button class="close-modal-btn" onclick="closeCreatePlaylistModal()">&times;</button>
                <h3 class="ban-reason-title">Create Custom Playlist</h3>
                <div class="playlist-modal-body">
                    <p style="color:#b3b3b3;font-size:0.85em;margin:0;">Name your playlist and add up to 5 songs for free. Additional songs cost <%= addPlaylistSongAmount %> digipogs each.</p>
                    <div class="row" style="margin:0;">
                        <label class="small">Playlist Name</label>
                        <input type="text" id="newPlaylistName" maxlength="100" placeholder="My Awesome Playlist" style="width:100%;box-sizing:border-box;" />
                    </div>
                    <div style="margin:0;">
                        <label class="small">Initial Songs (up to 5)</label>
                        <form id="createPlaylistSearchForm" style="margin-top:6px;">
                            <div class="search-container">
                                <input type="text" id="createPlaylistSearchInput" placeholder="Search for a song" style="flex:1;" />
                                <button type="submit" class="primary" style="padding:6px 12px;">Search</button>
                            </div>
                        </form>
                        <div id="createPlaylistSearchResults" class="playlist-search-results"></div>
                    </div>
                    <div id="createPlaylistSelectedSongs" class="playlist-selected-songs"></div>
                </div>
                <div class="playlist-modal-footer ban-reason-actions" style="display:flex;gap:8px;">
                    <button class="unban-button" onclick="submitCreatePlaylist()">Create &amp; Pay (<%= createPlaylistAmount %> digipogs)</button>
                    <button class="ban-button" onclick="closeCreatePlaylistModal()">Cancel</button>
                </div>
            </div>
        </div>

        <!-- Custom Playlist Tracks Modal -->
        <div id="customPlaylistTracksModal" class="payment-modal" style="display:none;">
            <div class="payment-content" style="max-height:85vh;overflow-y:auto;">
                <button class="close-modal-btn" onclick="closeCustomPlaylistTracksModal()">&times;</button>
                <h3 class="ban-reason-title" id="customPlaylistTracksTitle">Playlist</h3>
                <div style="margin-bottom:10px;">
                    <button class="primary small-btn" onclick="openAddSongToCustomPlaylist()">+ Add Song (<%= addPlaylistSongAmount %> digipogs)</button>
                </div>
                <div id="customPlaylistTracksList" class="playlist-tracks-list">
                    <p style="color:#b3b3b3;text-align:center;padding:12px;">Loading tracks...</p>
                </div>
            </div>
        </div>

        <!-- Add Song to Custom Playlist Modal -->
        <div id="addSongToPlaylistModal" class="payment-modal" style="display:none;">
            <div class="payment-content" style="max-height:85vh;overflow-y:auto;">
                <button class="close-modal-btn" onclick="closeAddSongToPlaylistModal()">&times;</button>
                <h3 class="ban-reason-title">Add Song to Playlist</h3>
                <form id="addSongSearchForm" style="margin-bottom:8px;">
                    <div class="search-container">
                        <input type="text" id="addSongSearchInput" placeholder="Search for a song" style="flex:1;" />
                        <button type="submit" class="primary" style="padding:6px 12px;">Search</button>
                    </div>
                </form>
                <div id="addSongSearchResults" class="playlist-search-results"></div>
            </div>
        </div>

        <button id="changelog-button" class="changelog-button" title="View Changelog">
            <img src="/img/changelog.png" alt="Changelog">
        </button>

        <div id="changelogModal" class="changelog-modal">
            <div class="changelog-content">
                <button id="close-changelog" class="close-changelog">&times;</button>
                <%- include('partials/changelog') %>
            </div>
        </div>

        <div id="banVoteModal" class="ban-vote-modal minimized" style="display: none;">
            <div class="ban-vote-header">
                <span id="banVoteStatus">Ban vote in progress...</span>
                <button id="banVoteMinimize" class="ban-vote-minimize-btn" title="Minimize/Maximize">−</button>
            </div>
            <div class="ban-vote-content">
                <h3 id="banVoteTitle"></h3>
                <div class="ban-vote-details">
                    <div class="vote-counts">
                        <span>Yes: <strong id="banVoteYes">0</strong></span>
                        <span>No: <strong id="banVoteNo">0</strong></span>
                        <span>Online: <strong id="banVoteOnline">0</strong></span>
                    </div>
                    <div class="vote-buttons">
                        <button onclick="castVote('yes')" class="vote-yes-btn">Vote Yes</button>
                        <button onclick="castVote('no')" class="vote-no-btn">Vote No</button>
                    </div>
                    <div id="vote-timer" class="vote-timer">45s remaining</div>
                </div>
            </div>
        </div>

        <script>
            // Notification functions - MUST be defined FIRST before any includes
            let notificationTimeout;

            function Notify(message, type = 'info', iconSrc = null) {
                let notification = document.getElementById("notification");
                let notificationText = document.getElementById("notification-text");

                notificationText.textContent = '';
                if (iconSrc) {
                    const icon = document.createElement('img');
                    icon.src = iconSrc;
                    icon.alt = '';
                    icon.className = 'notify-shield-icon';
                    notificationText.appendChild(icon);
                    notificationText.appendChild(document.createTextNode(' ' + message));
                } else {
                    notificationText.textContent = message;
                }

                // Remove any existing type classes
                notification.classList.remove('notification-success', 'notification-error', 'notification-info');

                // Add the appropriate type class
                if (type === 'error') {
                    notification.classList.add('notification-error');
                } else {
                    // default to success for other types
                    notification.classList.add('notification-success');
                }

                notification.style.display = "block";
                setTimeout(() => notification.style.opacity = "1", 100);

                clearTimeout(notificationTimeout);
                notificationTimeout = setTimeout(closeNotification, 5000);
            }

            function closeNotification() {
                let notification = document.getElementById("notification");
                clearTimeout(notificationTimeout);

                notification.style.opacity = "0";
                setTimeout(() => notification.style.display = "none", 500);
            }

            const userPermission = <%= userPermission %>;

            // Global payment status flags - MUST be at top for songMenu.ejs to access
            let hasPaid = <%= JSON.stringify(hasPaid || false) %>;
            let pendingTrackUri = null;
            let pendingTrackAddedAt = null;
            let pendingTrackName = null;
            let pendingTrackArtist = null;
            let pendingBanReason = null;
            let pendingAction = null;
            let pendingShieldQuantity = 1;
            let pendingPlaylistId = null;
            let selectedPlaylistQuote = null;

            // Custom playlist state
            let pendingCustomPlaylistId = null;
            let pendingCustomPlaylistName = null;
            let pendingCustomPlaylistTrackUri = null;
            let createPlaylistSelectedUris = [];
            let currentCustomPlaylistId = null;

            // Global letiables that need to be accessed by multiple functions
            let currentlyPlayingUri = null;
            let currentProgress = 0; // Current progress in ms
            let currentDuration = 0; // Track duration in ms
            let isCurrentlyPlaying = false;
            let progressInterval = null;
            let currentID = <%= JSON.stringify(userID || null) %>; // User ID which is needed by ban votes
            const ownerIDs = <%= JSON.stringify(ownerIDs) %>; // Array of owner ids

            // Helper function to check if a user ID is an owner
            function isOwnerClient(uid) {
                return ownerIDs.includes(Number(uid));
            }

            // Create socket globally one time and expose it immediately
            const socket = io();
            window.banVoteSocket = socket;
        </script>

        <%- include('partials/songMenu') %>

            <script>
                let currentTrackActionState = null;

                (function () {
                    'use strict';

                    let useJukebar = true;
                    let userIsBanned = false;

                    async function fetchAllowedPlaylistsForSidebar() {
                        const list = document.getElementById('studentPlaylistsList');
                        if (!list) return;

                        list.innerHTML = '<p style="text-align:center;color:#b3b3b3;">Loading...</p>';

                        try {
                            const res = await fetch('/api/playlists/allowed', { headers: { 'Accept': 'application/json' } });
                            const data = await res.json().catch(() => ({}));
                            if (!res.ok || !data.ok) throw new Error(data.error || 'Failed to load playlists');

                            const playlists = data.playlists || [];
                            if (!playlists.length) {
                                list.innerHTML = '<p style="text-align:center;color:#b3b3b3;">No playlists yet.</p>';
                                return;
                            }

                            list.innerHTML = '';
                            playlists.slice(0, 30).forEach((p) => {
                                const row = document.createElement('button');
                                row.type = 'button';
                                row.className = 'player-sidebar-item';
                                row.title = p.name || 'Playlist';

                                const img = document.createElement('img');
                                img.className = 'player-sidebar-cover';
                                img.src = p.image || '/img/placeholder.png';
                                img.alt = p.name || 'Playlist';

                                const meta = document.createElement('div');
                                meta.className = 'player-sidebar-meta';

                                const name = document.createElement('div');
                                name.className = 'player-sidebar-name';
                                name.textContent = p.name || 'Untitled Playlist';

                                const sub = document.createElement('div');
                                sub.className = 'player-sidebar-sub';
                                sub.textContent = p.owner ? `By ${p.owner}` : 'Playlist';

                                meta.appendChild(name);
                                meta.appendChild(sub);

                                row.appendChild(img);
                                row.appendChild(meta);

                                row.addEventListener('click', () => handlePlaylistClick(p));

                                list.appendChild(row);
                            });
                        } catch (err) {
                            console.error('Sidebar playlists load error:', err);
                            list.innerHTML = '<p style="text-align:center;color:#ff4444;">Failed to load playlists.</p>';
                        }
                    }

                    async function handlePlaylistClick(playlist) {
                        if (userIsBanned) {
                            Notify('You are banned from using Jukebar.', 'error');
                            return;
                        }

                        Notify('Loading playlist...', 'success');

                        // Owners skip payment — queue directly
                        if (isOwnerClient(currentID)) {
                            await queuePlaylist(playlist.id);
                            return;
                        }

                        // Get a cost quote first
                        try {
                            const quoteRes = await fetch('/api/playlists/quote', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ playlistId: playlist.id })
                            });
                            const quoteData = await quoteRes.json();
                            if (!quoteRes.ok || !quoteData.ok) {
                                Notify(quoteData.error || 'Cannot play this playlist', 'error');
                                return;
                            }

                            if (!quoteData.queueableCount || quoteData.cost <= 0) {
                                Notify('No queueable tracks in this playlist right now.', 'error');
                                return;
                            }

                            // Show the dedicated playlist payment modal
                            selectedPlaylistQuote = {
                                playlistId: playlist.id,
                                playlist: quoteData.playlist,
                                queueableCount: quoteData.queueableCount,
                                cost: quoteData.cost
                            };
                            document.getElementById('playlistPayTitle').textContent = quoteData.playlist?.name || 'Playlist';
                            document.getElementById('playlistPayMeta').textContent = `${quoteData.queueableCount} queueable tracks`;
                            document.getElementById('playlistPayCost').textContent = `${quoteData.cost} Digipogs`;
                            document.getElementById('playlistPaymentModal').style.display = 'block';
                            document.querySelector('.main-content').classList.add('blurred');
                        } catch (err) {
                            console.error('Playlist quote error:', err);
                            Notify('Something went wrong. Try again.', 'error');
                        }
                    }

                    async function queuePlaylist(playlistId) {
                        try {
                            const res = await fetch('/api/playlists/queue', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ playlistId })
                            });
                            const data = await res.json();
                            if (res.ok && data.ok) {
                                Notify(data.message || 'Playlist is now playing!', 'success');
                            } else {
                                Notify(data.error || 'Failed to play playlist', 'error');
                            }
                        } catch (err) {
                            console.error('Queue playlist error:', err);
                            Notify('Something went wrong. Try again.', 'error');
                        }
                    }


                    // Check if user is banned on page load
                    async function checkBanStatus() {
                        try {
                            const res = await fetch('/api/me/banned', { headers: { 'Accept': 'application/json' } });
                            if (res.ok) {
                                const data = await res.json();
                                if (data.banned) {
                                    userIsBanned = true;
                                    showBanBanner();
                                }
                            }
                        } catch (err) {
                            console.error('Error checking ban status:', err);
                        }
                    }

                    function showBanBanner() {
                        // Remove existing banner if any
                        const existing = document.getElementById('ban-banner');
                        if (existing) existing.remove();

                        const banner = document.createElement('div');
                        banner.id = 'ban-banner';
                        banner.style.cssText = 'position:fixed;bottom:0;left:0;right:0;z-index:10000;background:#ff4444;color:#fff;text-align:center;padding:12px 16px;font-weight:600;font-size:1rem;box-shadow:0 -2px 8px rgba(0,0,0,0.3);';
                        banner.textContent = '🚫 You have been banned from Jukebar. LOL COULD NOT BE ME AHAHAHAHAHAH';
                        document.body.appendChild(banner);
                    }

                    checkBanStatus();
                    fetchAllowedPlaylistsForSidebar();

                    document.getElementById('now-ban-button')?.addEventListener('click', async () => {
                        const actionTrack = currentTrackActionState;
                        if (!actionTrack) {
                            Notify('No track is currently playing.', 'error');
                            return;
                        }
                        if (userIsBanned) {
                            Notify('You have been banned from Jukebar. Contact your teacher.', 'error');
                            return;
                        }

                        try {
                            const res = await fetch('/api/online-count');
                            const data = await res.json().catch(() => ({}));
                            const onlineCount = data.count || 0;
                            if (onlineCount < 5) {
                                Notify('At least 5 users must be online to start a ban vote', 'error');
                                return;
                            }
                        } catch (err) {
                            console.error('Failed to check online count:', err);
                            Notify('Failed to verify online users. Please try again.', 'error');
                            return;
                        }

                        const userIsOwner = isOwnerClient(currentID);
                        if (userIsOwner) {
                            startBanVote(actionTrack.uri, actionTrack.name, actionTrack.artist, 'student ban');
                        } else {
                            pendingAction = 'Ban Vote';
                            pendingTrackUri = actionTrack.uri;
                            pendingTrackName = actionTrack.name;
                            pendingTrackArtist = actionTrack.artist;
                            pendingBanReason = 'student ban';
                            showPayment();
                        }
                    });

                    document.getElementById('now-shield-button')?.addEventListener('click', async () => {
                        const actionTrack = currentTrackActionState;
                        if (!actionTrack?.uri) {
                            Notify('No track is currently playing.', 'error');
                            return;
                        }

                        try {
                            const checkResponse = await fetch('/checkTrackExists', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ trackUri: actionTrack.uri })
                            });
                            const result = await checkResponse.json().catch(() => ({}));
                            if (!result.exists) {
                                Notify('This song has left the queue and can no longer be shielded.');
                                return;
                            }

                            if (typeof window.purchaseShield === 'function') {
                                window.purchaseShield(actionTrack.uri, actionTrack.addedAt || 0);
                            } else {
                                Notify('Unable to purchase shield.', 'error');
                            }
                        } catch (err) {
                            console.error('Error checking track for shield:', err);
                            Notify('Unable to verify track status', 'error');
                        }
                    });

                    // Real-time ban/unban via WebSocket
                    socket.on('userBanned', (data) => {
                        if (data.userId == currentID) {
                            userIsBanned = true;
                            showBanBanner();
                            Notify('You have been banned from Jukebar by your teacher.', 'error');
                        }
                    });

                    socket.on('userUnbanned', (data) => {
                        if (data.userId == currentID) {
                            userIsBanned = false;
                            const banner = document.getElementById('ban-banner');
                            if (banner) banner.remove();
                            Notify('You have been unbanned! You can use Jukebar again.', 'success');
                        }
                    });

                    socket.on('auxiliaryPermission', (permission) => {
                        if (permission <= userPermission) {
                            useJukebar = true;
                        } else {
                            useJukebar = false;
                        }
                    });

                    // Update online user count
                    socket.on('userCount', (count) => {
                        const countElement = document.getElementById('onlineUserCount');
                        if (countElement) {
                            countElement.textContent = count;
                        }
                    });

                    function handleSearchSubmit(event) {
                        event.preventDefault();
                        searchSpotify();
                    }

                    async function checkPaymentAndPlay(uri) {
                        // Check if user is banned
                        if (userIsBanned) {
                            Notify('You have been banned from Jukebar. Contact your teacher.', 'error');
                            return;
                        }

                        // Check if Jukebar is enabled
                        if (!useJukebar) {
                            Notify('Jukebar is currently disabled by your teacher.', 'error');
                            return;
                        }

                        if (isOwnerClient(currentID)) {
                            const anonMode = document.getElementById('owner-anon-mode')?.checked || false;
                            addToQueue(uri, anonMode);
                            return;
                        }

                        if (!hasPaid) {
                            pendingTrackUri = uri;
                            pendingAction = 'play';
                            showPayment();
                            return;
                        }

                        // Reset payment flag after using it
                        hasPaid = false;
                        addToQueue(uri);
                    }

                    async function checkPaymentAndSkip() {
                        console.log('⏭️ Skip clicked - currentlyPlayingUri:', currentlyPlayingUri);

                        // Check if user is banned
                        if (userIsBanned) {
                            Notify('You have been banned from Jukebar. Contact your teacher.', 'error');
                            return;
                        }

                        // Check if Jukebar is enabled
                        if (!useJukebar) {
                            Notify('Jukebar is currently disabled by your teacher.', 'error');
                            return;
                        }

                        // Build the full URI - add prefix only if not already present
                        let skipUri = currentlyPlayingUri;
                        if (currentlyPlayingUri && !currentlyPlayingUri.startsWith('spotify:track:')) {
                            skipUri = `spotify:track:${currentlyPlayingUri}`;
                        }

                        console.log('⏭️ Final skipUri:', skipUri);

                        if (isOwnerClient(currentID)) {
                            skip(skipUri);
                            return;
                        }

                        if (!hasPaid) {
                            pendingTrackUri = skipUri;
                            pendingAction = 'skip';
                            showPayment();
                            return;
                        }

                        // Reset payment flag after using it
                        hasPaid = false;
                        skip(skipUri);
                    }

                    async function skip(uri) {
                        try {
                            const response = await fetch('/skip', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ uri })
                            });

                            const data = await response.json();

                            if (data.shieldBlocked) {
                                // Skip was blocked by a shield
                                Notify(data.message || 'Skip blocked by shield!', 'error', '/img/skipShield.png');
                                // Request queue update to show updated shield count
                                socket.emit('getQueue');
                            } else if (data.ok) {
                                // Skip succeeded
                                Notify('Track skipped!', 'success');
                            } else {
                                // Other error
                                Notify(data.error || 'Failed to skip', 'error');
                                refund();
                            }
                        } catch (error) {
                            console.error('Error skipping track:', error);
                            Notify('Network error', 'error');
                        }
                    }

                    function addToQueue(uri, anonMode = null) {
                        if (anonMode === null) {
                            anonMode = document.getElementById('anonMode')?.checked || false;
                        }
                        fetch('/addToQueue', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ uri, anonMode })
                        })
                            .then(response => {
                                if (response.ok) {
                                    Notify('Track added to queue!', 'success');
                                } else {
                                    return response.json().then(data => {
                                        Notify(data.error || 'Failed to add track to queue', 'error');
                                        refund();
                                    });
                                }
                            })
                            .catch(error => {
                                //console.log('oopsies!')
                                console.error('Error adding track to queue:', error);
                                Notify('Network error', 'error');
                            });
                    }

                    let searchNextOffset = 0;
                    let searchCurrentQuery = '';

                    function renderSearchResults(tracks, resultsDiv) {
                        tracks.forEach(track => {
                            const trackDiv = document.createElement('div');
                            trackDiv.className = 'search-result-item';
                            trackDiv.innerHTML = `
                        <img src="${track.album.image}" alt="${track.album.name}" class="album-cover" />
                        <div class="search-result-content-outer">
                            <div class="thebackgroundoftheitemsthatareinthesearchresults"></div>
                            <div class="search-result-content-pushies">
                                <div class="search-result-title" title="${track.name}">${track.name}</div>
                                <div class="search-result-artist" title="${track.artist}">${track.artist}</div>
                                <div class="search-result-actions">
                                    <button class="play-button-icon" data-uri="${track.uri}" title="Add to queue">
                                        <img src="/img/play.png" alt="Play" class="play-icon">
                                    </button>
                                    <button class="ban-button-icon" data-uri="${track.uri}" data-name="${track.name.replace(/"/g, '&quot;')}" data-artist="${track.artist.replace(/"/g, '&quot;')}" title="Vote to ban">
                                        <img src="/img/ban.png" alt="Ban" class="ban-icon">
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                            resultsDiv.appendChild(trackDiv);
                        });
                    }

                    function removeLoadMoreButton() {
                        document.getElementById('loadMoreBtn')?.remove();
                    }

                    function addLoadMoreButton(resultsDiv) {
                        removeLoadMoreButton();
                        const btn = document.createElement('button');
                        btn.id = 'loadMoreBtn';
                        btn.className = 'load-more-btn';
                        btn.textContent = 'Load More';
                        btn.addEventListener('click', () => loadMoreResults());
                        resultsDiv.appendChild(btn);
                    }

                    async function loadMoreResults() {
                        if (!searchCurrentQuery || searchNextOffset <= 0) return;
                        const btn = document.getElementById('loadMoreBtn');
                        if (btn) { btn.textContent = 'Loading...'; btn.disabled = true; }

                        try {
                            const response = await fetch('/search', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ query: searchCurrentQuery, offset: searchNextOffset })
                            });
                            const data = await response.json();
                            const resultsDiv = document.getElementById('searchResults');
                            removeLoadMoreButton();

                            if (data.tracks && data.tracks.items.length > 0) {
                                renderSearchResults(data.tracks.items, resultsDiv);
                                searchNextOffset = data.nextOffset || 0;
                                if (data.hasMore) {
                                    addLoadMoreButton(resultsDiv);
                                }
                            }
                        } catch (error) {
                            console.error('Error loading more results:', error);
                            if (btn) { btn.textContent = 'Load More'; btn.disabled = false; }
                        }
                    }

                    async function searchSpotify() {
                        const query = document.getElementById('searchInput').value;
                        if (!query) return;
                        searchCurrentQuery = query;

                        try {
                            const response = await fetch('/search', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ query, offset: 0 })
                            });
                            const data = await response.json();
                            const resultsDiv = document.getElementById('searchResults');
                            resultsDiv.innerHTML = '';

                            if (data.tracks && data.tracks.items.length > 0) {
                                renderSearchResults(data.tracks.items, resultsDiv);
                                searchNextOffset = data.nextOffset || 0;
                                if (data.hasMore) {
                                    addLoadMoreButton(resultsDiv);
                                }
                            } else {
                                resultsDiv.innerHTML = '<p>No results found.</p>';
                            }
                        } catch (error) {
                            console.error('Error searching Spotify:', error);
                        }
                    }

