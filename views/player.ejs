                    document.getElementById('playlist-pay-confirm')?.addEventListener('click', async () => {
                        if (!selectedPlaylistQuote?.playlistId) {
                            Notify('No playlist selected.', 'error');
                            return;
                        }

                        const pin = document.getElementById('playlist-pay-pin').value.trim();
                        if (!pin) {
                            Notify('Please enter your PIN.', 'error');
                            return;
                        }

                        const confirmBtn = document.getElementById('playlist-pay-confirm');
                        confirmBtn.disabled = true;

                        try {
                            if (document.getElementById('playlistSavePIN')?.checked) {
                                await fetch('/savePin', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ pin })
                                }).catch(() => { });
                            }

                            const reason = `Jukebar Payment - Play Playlist (${selectedPlaylistQuote.playlist?.name || 'Playlist'})`;
                            const transferRes = await fetch('/transfer', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    pin,
                                    reason,
                                    pendingAction: 'playlist',
                                    playlistId: selectedPlaylistQuote.playlistId
                                })
                            });
