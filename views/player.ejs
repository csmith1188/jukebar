                    // Skip activity box minimize/expand toggle
                    (function initSkipActivityToggle() {
                        const box = document.getElementById('skipActivityBox');
                        const btn = document.getElementById('skipActivityToggle');
                        if (!box || !btn) return;

                        const STORAGE_KEY = 'skipActivityMinimized';

                        function applyState(minimized) {
                            box.classList.toggle('minimized', minimized);
                            btn.innerHTML = minimized ? '&#43;' : '&minus;';
                            btn.title = minimized ? 'Expand' : 'Minimize';
                            btn.setAttribute('aria-label', minimized ? 'Expand skip activity' : 'Minimize skip activity');
                        }

                        applyState(localStorage.getItem(STORAGE_KEY) === 'true');

                        btn.addEventListener('click', () => {
                            const nowMinimized = !box.classList.contains('minimized');
                            localStorage.setItem(STORAGE_KEY, nowMinimized);
                            applyState(nowMinimized);
                        });
                    })();

