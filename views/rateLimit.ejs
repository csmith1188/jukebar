<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/img/brokey.png" />
  <style>
    html, body {
      margin: 0;
      width: 100%;
      height: 100%;
      background: #000;
      color: #fff;
      font-family: Arial, sans-serif;
    }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 24px;
      box-sizing: border-box;
    }
    .wrap {
      max-width: 920px;
    }
    .art {
      width: min(320px, 80vw);
      height: auto;
      margin: 0 auto 18px;
      display: block;
    }
    .msg {
      font-size: 2rem;
      line-height: 1.35;
      margin: 0 0 10px;
    }
    .timer {
      font-size: 1.1rem;
      color: rgba(255, 255, 255, 0.85);
    }
  </style>
</head>
<body>
  <main class="wrap">
    <p class="msg"><%= message %></p>
    <p class="timer">Retry in <strong id="retrySeconds"><%= retryAfterSeconds %></strong>s</p>
  </main>

  <script>
    (function startCountdown() {
      var el = document.getElementById('retrySeconds');
      if (!el) return;
      var remaining = Number(el.textContent) || 0;
      function tick() {
        if (remaining <= 0) {
          el.textContent = '0';
          window.location.reload();
          return;
        }
        remaining -= 1;
        el.textContent = String(remaining);
        window.setTimeout(tick, 1000);
      }
      window.setTimeout(tick, 1000);
    })();
  </script>
</body>
</html>
