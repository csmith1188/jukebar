<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Playlists</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body data-is-teacher="<%= isTeacher ? '1' : '0' %>">
  <header>
    <div class="row">
      <a href="/" class="muted">← Back</a>
      <strong>Playlists</strong>
      <span class="pill"><%= isTeacher ? 'Teacher' : 'Student' %></span>
    </div>
    <div class="row">
      <% if (isTeacher) { %>
        <button id="btnRefresh">Refresh from Spotify</button>
      <% } %>
      <button id="btnReload">Reload</button>
    </div>
  </header>

  <div class="wrap">
    <div id="status" class="muted">Loading…</div>
    <div id="error" class="err" style="display:none;"></div>
    <div class="grid" id="grid"></div>
  </div>

  <script>
    // Keep script tag. Browser-side JS only.
    const IS_TEACHER = document.body.getAttribute('data-is-teacher') === '1';

    // API endpoints
    const API = {
      list: () => (IS_TEACHER ? '/api/playlists/teacher' : '/api/playlists'),
      refresh: () => '/api/playlists/refresh',
      enable: (id) => `/api/playlists/${encodeURIComponent(id)}/enable`,
      disable: (id) => `/api/playlists/${encodeURIComponent(id)}/disable`,
      play: (id) => `/api/playlists/${encodeURIComponent(id)}/play`
    };

    const els = {
      status: document.getElementById('status'),
      error: document.getElementById('error'),
      grid: document.getElementById('grid'),
      btnReload: document.getElementById('btnReload'),
      btnRefresh: document.getElementById('btnRefresh')
    };

    function setError(msg) {
      els.error.style.display = msg ? 'block' : 'none';
      els.error.textContent = msg || '';
    }

    function fmtMs(ms) {
      const totalSec = Math.max(0, Math.floor((ms || 0) / 1000));
      const m = Math.floor(totalSec / 60);
      const s = totalSec % 60;
      return `${m}:${String(s).padStart(2, '0')}`;
    }

    function esc(str) {
      return String(str || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function cardHtml(p) {
      const enabled = !!p.enabled_for_students;
      const cost = p.cost_digipogs != null ? `${p.cost_digipogs} digipogs` : null;

      return `
        <div class="card" data-id="${esc(p.spotify_playlist_id)}">
          <div class="img">${p.image_url ? `<img src="${esc(p.image_url)}" alt="">` : ''}</div>
          <div class="content">
            <p class="title" title="${esc(p.name)}">${esc(p.name || 'Untitled playlist')}</p>
            <div class="meta">
              ${p.owner_name ? `By ${esc(p.owner_name)} · ` : ''}
              ${p.track_count != null ? `${p.track_count} tracks · ` : ''}
              ${p.total_duration_ms != null ? `${fmtMs(p.total_duration_ms)} · ` : ''}
              ${cost ? esc(cost) : ''}
            </div>

            <div class="actions">
              ${IS_TEACHER ? `
                <span class="pill ${enabled ? 'ok' : 'no'}">${enabled ? 'Enabled' : 'Disabled'}</span>
                <button class="btnToggle">${enabled ? 'Disable for students' : 'Enable for students'}</button>
              ` : `
                <button class="primary btnPlay">Play</button>
              `}
            </div>
          </div>
        </div>
      `;
    }

    async function apiFetch(url, opts = {}) {
      const res = await fetch(url, {
        method: opts.method || 'GET',
        headers: { 'Content-Type': 'application/json' },
        body: opts.body ? JSON.stringify(opts.body) : undefined
      });

      const data = await res.json().catch(() => ({}));
      if (!res.ok || data.ok === false) {
        throw new Error(data.error || `Request failed (${res.status})`);
      }
      return data;
    }

    async function load() {
      setError('');
      els.status.textContent = 'Loading…';
      els.grid.innerHTML = '';

      const data = await apiFetch(API.list());
      const playlists = data.playlists || [];

      els.status.textContent = playlists.length ? `${playlists.length} playlist(s)` : 'No playlists.';
      els.grid.innerHTML = playlists.map(cardHtml).join('');
    }

    async function onGridClick(e) {
      const card = e.target.closest('.card');
      if (!card) return;
      const id = card.getAttribute('data-id');

      if (e.target.classList.contains('btnPlay')) {
        e.target.disabled = true;
        try {
          await apiFetch(API.play(id), { method: 'POST' });
          els.status.textContent = 'Playlist started.';
        } catch (err) {
          setError(err.message || String(err));
        } finally {
          e.target.disabled = false;
        }
      }

      if (e.target.classList.contains('btnToggle')) {
        e.target.disabled = true;
        try {
          const pill = card.querySelector('.pill');
          const isEnabled = pill && pill.textContent.trim().toLowerCase() === 'enabled';
          await apiFetch(isEnabled ? API.disable(id) : API.enable(id), { method: 'POST' });
          await load();
        } catch (err) {
          setError(err.message || String(err));
        } finally {
          e.target.disabled = false;
        }
      }
    }

    els.grid.addEventListener('click', onGridClick);
    els.btnReload.addEventListener('click', () => load().catch(err => setError(err.message || String(err))));

    if (els.btnRefresh) {
      els.btnRefresh.addEventListener('click', async () => {
        els.btnRefresh.disabled = true;
        setError('');
        try {
          els.status.textContent = 'Refreshing…';
          await apiFetch(API.refresh(), { method: 'POST' });
          await load();
        } catch (err) {
          setError(err.message || String(err));
        } finally {
          els.btnRefresh.disabled = false;
        }
      });
    }

    load().catch(err => setError(err.message || String(err)));
  </script>
</body>
</html>